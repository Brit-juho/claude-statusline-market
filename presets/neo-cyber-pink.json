{
  "id": "neo-cyber-pink",
  "version": "0.1.0",
  "title": { "ko": "사이버 핑크", "en": "Cyber Pink" },
  "description": {
    "ko": "핑크·마젠타 팔레트의 사이버펑크 스타일 — 세션, 노력, 비용을 강렬하게",
    "en": "Cyberpunk pink-magenta palette — session, effort, cost rendered with punch"
  },
  "tool": "ccstatusline",
  "category": "custom",
  "tags": ["cyberpunk", "pink", "magenta", "bold"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": " ▸ ",
      "segments": [
        { "type": "model",      "format": "◆ {model}",              "style": "pink bold" },
        { "type": "effort",     "format": "{effort_level}",          "style": "magenta bold" },
        { "type": "cwd",        "format": "{dir_name}",              "style": "pink" },
        { "type": "cost",       "format": "${total_cost_usd:.4f}",   "style": "magenta" },
        { "type": "duration",   "format": "{duration}",              "style": "dim" }
      ]
    }
  }
}
