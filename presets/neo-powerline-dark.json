{
  "id": "neo-powerline-dark",
  "version": "0.1.0",
  "title": { "ko": "파워라인 다크", "en": "Powerline Dark" },
  "description": {
    "ko": "색상으로 구분된 파워라인 — 모델, 디렉터리, 브랜치, 컨텍스트, 비용을 한 줄에",
    "en": "Color-coded powerline — model, dir, branch, context, cost in one clean line"
  },
  "tool": "ccstatusline",
  "category": "powerline",
  "tags": ["powerline", "colors", "git", "context"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  ╱  ",
      "segments": [
        { "type": "model",       "format": "◆ {model}",              "style": "cyan bold" },
        { "type": "cwd",         "format": "{dir_name}",              "style": "blue" },
        { "type": "git_branch",  "format": "⎇ {branch}",             "style": "green" },
        { "type": "context_bar", "format": "{used_percentage}%",      "style": "yellow" },
        { "type": "cost",        "format": "${total_cost_usd:.4f}",   "style": "dim" }
      ]
    }
  }
}
