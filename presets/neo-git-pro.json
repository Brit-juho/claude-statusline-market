{
  "id": "neo-git-pro",
  "version": "0.1.0",
  "title": { "ko": "Git 프로", "en": "Git Pro" },
  "description": {
    "ko": "Git 작업에 최적화 — 브랜치, 변경 파일, 추가/삭제 라인, 디렉터리를 색상으로 구분",
    "en": "Optimized for Git work — branch, changes, added/removed lines with color coding"
  },
  "tool": "ccstatusline",
  "category": "git",
  "tags": ["git", "branch", "diff", "colors"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  ",
      "segments": [
        { "type": "git_branch",  "format": "⎇ {branch}",                         "style": "green bold" },
        { "type": "git_changes", "format": "~{changed}",                           "style": "yellow" },
        { "type": "lines_changed","format": "+{total_lines_added} -{total_lines_removed}", "style": "cyan" },
        { "type": "cwd",         "format": "{dir_name}",                           "style": "blue" },
        { "type": "model",       "format": "{model}",                              "style": "dim" }
      ]
    }
  }
}
