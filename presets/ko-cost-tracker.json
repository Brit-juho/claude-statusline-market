{
  "id": "ko-cost-tracker",
  "version": "0.1.0",
  "title": {
    "ko": "비용 추적기",
    "en": "Cost Tracker"
  },
  "description": {
    "ko": "세션별 API 비용을 실시간으로 추적합니다. 토큰 수, 캐시 히트율, 누적 비용을 한눈에",
    "en": "Track API costs in real time. Tokens, cache hit rate, and cumulative cost at a glance"
  },
  "tool": "ccstatusline",
  "category": "cost",
  "tags": ["cost", "tokens", "cache", "budget"],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  ",
      "segments": [
        {
          "type": "model",
          "enabled": true,
          "format": "[{model}]"
        },
        {
          "type": "tokens",
          "enabled": true,
          "format": "in:{input_tokens} out:{output_tokens}",
          "style": "dim"
        },
        {
          "type": "cache",
          "enabled": true,
          "format": "cache:{cache_hit_rate:.0f}%",
          "style": "green"
        },
        {
          "type": "cost",
          "enabled": true,
          "format": "cost:${total_cost:.4f}",
          "style": "yellow"
        }
      ]
    }
  }
}
