{
  "id": "ko-minimal",
  "version": "0.1.0",
  "title": {
    "ko": "미니멀",
    "en": "Minimal"
  },
  "description": {
    "ko": "꼭 필요한 정보만 — 모델명과 비용만 표시하는 깔끔한 한 줄",
    "en": "Only the essentials — a clean single line showing model and cost"
  },
  "tool": "ccstatusline",
  "category": "minimal",
  "tags": ["minimal", "clean", "beginner"],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": " | ",
      "segments": [
        {
          "type": "model",
          "enabled": true,
          "format": "{model}"
        },
        {
          "type": "cost",
          "enabled": true,
          "format": "${total_cost:.4f}"
        }
      ]
    }
  }
}
