{
  "id": "ko-productivity",
  "version": "0.1.0",
  "title": {
    "ko": "생산성 올인원",
    "en": "Productivity All-in-One"
  },
  "description": {
    "ko": "생산성 극대화를 위한 올인원 설정 — 시간, 작업 수, 토큰, Git, 비용을 모두 표시",
    "en": "All-in-one for maximum productivity — time, tasks, tokens, Git, and cost in one bar"
  },
  "tool": "ccstatusline",
  "category": "productivity",
  "tags": ["productivity", "all-in-one", "time", "tasks"],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": " | ",
      "segments": [
        {
          "type": "session_time",
          "enabled": true,
          "format": "{duration}",
          "style": "dim"
        },
        {
          "type": "git",
          "enabled": true,
          "format": "{branch}",
          "style": "blue"
        },
        {
          "type": "model",
          "enabled": true,
          "format": "{model}"
        },
        {
          "type": "tokens",
          "enabled": true,
          "format": "{total_tokens}tok",
          "style": "dim"
        },
        {
          "type": "cost",
          "enabled": true,
          "format": "${total_cost:.4f}",
          "style": "green"
        }
      ]
    }
  }
}
