{
  "id": "ko-dark-zen",
  "version": "0.1.0",
  "title": {
    "ko": "다크 젠",
    "en": "Dark Zen"
  },
  "description": {
    "ko": "집중을 방해하지 않는 극도로 조용한 상태바 — 모델과 세션 시간만 표시",
    "en": "Ultra-quiet status bar that won't break your flow — just model and session time"
  },
  "tool": "ccstatusline",
  "category": "minimal",
  "tags": ["minimal", "zen", "focus", "quiet"],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  ",
      "segments": [
        {
          "type": "model",
          "enabled": true,
          "format": "{model}",
          "style": "dim"
        },
        {
          "type": "session_time",
          "enabled": true,
          "format": "{duration}",
          "style": "dim"
        }
      ]
    }
  }
}
