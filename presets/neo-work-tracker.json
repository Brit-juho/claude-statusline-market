{
  "id": "neo-work-tracker",
  "version": "0.1.0",
  "title": { "ko": "작업 트래커", "en": "Work Tracker" },
  "description": {
    "ko": "개발 생산성 추적 — 경과 시간, 코드 변경량, Git 상태, 컨텍스트 사용률",
    "en": "Dev productivity tracking — elapsed time, code delta, Git state, context usage"
  },
  "tool": "ccstatusline",
  "category": "productivity",
  "tags": ["productivity", "time", "git", "lines"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  │  ",
      "segments": [
        { "type": "duration",     "format": "◷ {duration}",                       "style": "cyan" },
        { "type": "git_branch",   "format": "⎇ {branch}",                         "style": "green" },
        { "type": "lines_changed","format": "+{total_lines_added} -{total_lines_removed}", "style": "yellow" },
        { "type": "context_bar",  "format": "{used_percentage}% ctx",              "style": "dim" },
        { "type": "model",        "format": "{model}",                             "style": "dim" }
      ]
    }
  }
}
