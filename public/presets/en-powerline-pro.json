{
  "id": "en-powerline-pro",
  "version": "0.1.0",
  "title": {
    "ko": "파워라인 프로",
    "en": "Powerline Pro"
  },
  "description": {
    "ko": "파워라인 스타일의 풀 정보 상태바 — Git, 모델, 토큰, 비용, 세션 시간 포함",
    "en": "Full-info powerline-style statusbar — Git, model, tokens, cost, and session time"
  },
  "tool": "ccstatusline",
  "category": "powerline",
  "tags": ["powerline", "git", "full-info", "advanced"],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  ",
      "segments": [
        {
          "type": "git",
          "enabled": true,
          "format": " {branch}",
          "style": "bold blue"
        },
        {
          "type": "model",
          "enabled": true,
          "format": " {model}",
          "style": "bold"
        },
        {
          "type": "tokens",
          "enabled": true,
          "format": "{input_tokens}+{output_tokens}",
          "style": "dim"
        },
        {
          "type": "cache",
          "enabled": true,
          "format": "C:{cache_hit_rate:.0f}%",
          "style": "cyan"
        },
        {
          "type": "cost",
          "enabled": true,
          "format": "${total_cost:.4f}",
          "style": "green"
        },
        {
          "type": "session_time",
          "enabled": true,
          "format": "{duration}",
          "style": "dim"
        }
      ]
    }
  }
}
