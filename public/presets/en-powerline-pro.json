{
  "id": "en-powerline-pro",
  "version": "0.1.0",
  "title": {
    "ko": "파워라인 프로",
    "en": "Powerline Pro"
  },
  "description": {
    "ko": "파워라인 스타일의 풀 정보 상태바 — Git, 모델, 토큰, 비용, 세션 시간 포함",
    "en": "Full-info powerline-style statusbar — Git, model, tokens, cost, and session time"
  },
  "tool": "ccstatusline",
  "category": "powerline",
  "tags": [
    "powerline",
    "git",
    "full-info",
    "advanced"
  ],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "ccstatusline_settings": {
    "version": 3,
    "lines": [
      [
        {
          "id": "1",
          "type": "git-status",
          "color": "blue",
          "bold": true
        },
        {
          "id": "2",
          "type": "model",
          "color": "dim",
          "bold": true
        },
        {
          "id": "3",
          "type": "tokens-total",
          "color": "dim"
        },
        {
          "id": "4",
          "type": "tokens-cached",
          "color": "cyan"
        },
        {
          "id": "5",
          "type": "session-cost",
          "color": "green"
        },
        {
          "id": "6",
          "type": "session-clock",
          "color": "dim"
        }
      ]
    ]
  }
}
