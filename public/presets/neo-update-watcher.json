{
  "id": "neo-update-watcher",
  "version": "0.1.0",
  "title": { "ko": "업데이트 감시자", "en": "Update Watcher" },
  "description": {
    "ko": "Claude Code 신버전 출시 시 즉시 알림 — 버전, 업데이트 배지, 컨텍스트를 한 줄에",
    "en": "Instant alert when a new Claude Code version drops — version, update badge, context in one line"
  },
  "tool": "ccstatusline",
  "category": "productivity",
  "tags": ["update", "version", "alert", "maintenance"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  ",
      "segments": [
        { "type": "model",         "format": "◆ {model}",              "style": "cyan" },
        { "type": "version_plain", "format": "v{version}",             "style": "dim",           "when": "always" },
        { "type": "update_badge",  "format": "↑ v{latest_version} NEW","style": "yellow bold",   "when": "update" },
        { "type": "context_bar",   "format": "{used_percentage}%",     "style": "green" },
        { "type": "cost",          "format": "${total_cost_usd:.4f}",  "style": "dim" }
      ]
    }
  }
}
