{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://netriogit.github.io/claude-statusline-market/presets/schema.json",
  "title": "Claude Statusline Preset",
  "description": "A preset configuration for ccstatusline",
  "type": "object",
  "required": ["id", "version", "title", "description", "tool", "category", "author", "ccstatusline_settings"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique kebab-case identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version"
    },
    "title": {
      "type": "object",
      "required": ["ko", "en"],
      "properties": {
        "ko": { "type": "string" },
        "en": { "type": "string" }
      },
      "additionalProperties": false
    },
    "description": {
      "type": "object",
      "required": ["ko", "en"],
      "properties": {
        "ko": { "type": "string" },
        "en": { "type": "string" }
      },
      "additionalProperties": false
    },
    "tool": {
      "type": "string",
      "enum": ["ccstatusline"],
      "description": "Target tool this preset configures"
    },
    "category": {
      "type": "string",
      "enum": ["minimal", "productivity", "cost", "git", "powerline", "custom"],
      "description": "Preset category for gallery filtering"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "github": { "type": "string" }
      },
      "additionalProperties": false
    },
    "screenshot": {
      "type": "string",
      "description": "Path to screenshot (auto-generated by CI)"
    },
    "ccstatusline_settings": {
      "type": "object",
      "description": "Native ccstatusline v3 settings object",
      "required": ["version", "lines"],
      "properties": {
        "version": {
          "type": "integer",
          "enum": [3],
          "description": "ccstatusline settings format version"
        },
        "lines": {
          "type": "array",
          "description": "Array of statusline lines, each line is an array of widget items",
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type"],
              "additionalProperties": true,
              "properties": {
                "id": { "type": "string", "description": "Unique widget ID within the line" },
                "type": {
                  "type": "string",
                  "description": "ccstatusline widget type identifier",
                  "enum": [
                    "model", "output-style", "thinking-effort", "version",
                    "claude-session-id", "claude-account-email", "session-name",
                    "context-percentage", "context-percentage-usable", "context-bar",
                    "context-length", "context-window",
                    "tokens-input", "tokens-output", "tokens-cached", "tokens-total",
                    "input-speed", "output-speed", "total-speed",
                    "session-cost", "session-clock", "session-usage",
                    "weekly-usage", "weekly-sonnet-usage", "weekly-opus-usage",
                    "extra-usage-utilization", "extra-usage-remaining",
                    "reset-timer", "weekly-reset-timer", "block-timer",
                    "free-memory", "terminal-width",
                    "skills", "vim-mode", "voice-status",
                    "compaction-counter",
                    "git-branch", "git-status", "git-changes",
                    "git-insertions", "git-deletions",
                    "git-staged-files", "git-unstaged-files", "git-untracked-files",
                    "git-staged", "git-unstaged", "git-untracked",
                    "git-clean-status", "git-ahead-behind", "git-conflicts",
                    "git-sha", "git-review", "git-worktree", "git-root-dir",
                    "git-origin-owner", "git-origin-repo", "git-origin-owner-repo",
                    "git-upstream-owner", "git-upstream-repo", "git-upstream-owner-repo",
                    "git-is-fork",
                    "current-working-dir",
                    "worktree-mode", "worktree-name", "worktree-branch", "worktree-original-branch",
                    "custom-text", "custom-symbol", "custom-command", "link", "separator"
                  ]
                },
                "color": { "type": "string", "description": "Widget color (named color or hex)" },
                "bold": { "type": "boolean", "description": "Render text in bold" },
                "commandPath": { "type": "string", "description": "Shell command for custom-command type" },
                "rawValue": { "type": "string", "description": "Static text for custom-text type" }
              }
            }
          }
        }
      }
    }
  }
}
