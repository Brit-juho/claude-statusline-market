{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://netriogit.github.io/claude-statusline-market/presets/schema.json",
  "title": "Claude Statusline Preset",
  "description": "A preset configuration for ccstatusline",
  "type": "object",
  "required": ["id", "version", "title", "description", "tool", "category", "author", "settings"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique kebab-case identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version"
    },
    "title": {
      "type": "object",
      "required": ["ko", "en"],
      "properties": {
        "ko": { "type": "string" },
        "en": { "type": "string" }
      },
      "additionalProperties": false
    },
    "description": {
      "type": "object",
      "required": ["ko", "en"],
      "properties": {
        "ko": { "type": "string" },
        "en": { "type": "string" }
      },
      "additionalProperties": false
    },
    "tool": {
      "type": "string",
      "enum": ["ccstatusline"],
      "description": "Target tool this preset configures"
    },
    "category": {
      "type": "string",
      "enum": ["minimal", "productivity", "cost", "git", "powerline", "custom"],
      "description": "Preset category for gallery filtering"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "github": { "type": "string" }
      },
      "additionalProperties": false
    },
    "screenshot": {
      "type": "string",
      "description": "Path to screenshot (auto-generated by CI)"
    },
    "settings": {
      "type": "object",
      "description": "ccstatusline settings object",
      "required": ["statusline"],
      "properties": {
        "statusline": {
          "type": "object",
          "required": ["enabled", "segments"],
          "properties": {
            "enabled": { "type": "boolean" },
            "position": {
              "type": "string",
              "enum": ["top", "bottom"],
              "default": "bottom"
            },
            "separator": { "type": "string" },
            "segments": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": { "type": "string" },
                  "enabled": { "type": "boolean" },
                  "format": { "type": "string" },
                  "style": { "type": "string" },
                  "options": { "type": "object" }
                }
              }
            }
          }
        }
      }
    }
  }
}
