{
  "id": "neo-session-rich",
  "version": "0.1.0",
  "title": { "ko": "세션 리치", "en": "Session Rich" },
  "description": {
    "ko": "세션 정보 풀 패키지 — ID, 추론 수준, 사고 모드, 버전, 경과 시간까지",
    "en": "Full session info — ID, effort level, thinking mode, version, and elapsed time"
  },
  "tool": "ccstatusline",
  "category": "productivity",
  "tags": ["session", "effort", "version", "time"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  │  ",
      "segments": [
        { "type": "model",        "format": "◆ {model}",         "style": "cyan bold" },
        { "type": "effort",       "format": "effort:{effort_level}", "style": "magenta" },
        { "type": "session_id",   "format": "#{session_id}",      "style": "dim" },
        { "type": "duration",     "format": "◷ {duration}",       "style": "yellow" },
        { "type": "version",      "format": "v{version}",         "style": "dim" }
      ]
    }
  }
}
