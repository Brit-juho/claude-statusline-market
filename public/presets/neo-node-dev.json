{
  "id": "neo-node-dev",
  "version": "0.1.0",
  "title": { "ko": "Node 개발자", "en": "Node Developer" },
  "description": {
    "ko": "Node.js 개발에 최적화 — Node 버전, 브랜치, 디렉터리, 비용을 한눈에",
    "en": "Optimized for Node.js dev — Node version, branch, dir, and cost at a glance"
  },
  "tool": "ccstatusline",
  "category": "custom",
  "tags": ["node", "javascript", "runtime", "git"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  ",
      "segments": [
        { "type": "model",       "format": "◆ {model}",              "style": "cyan bold" },
        { "type": "cwd",         "format": "{dir_name}",              "style": "blue" },
        { "type": "git_branch",  "format": "⎇ {branch}",             "style": "green" },
        { "type": "runtime",     "format": "node {node_version}",     "style": "green bold" },
        { "type": "cost",        "format": "${total_cost:.4f}",       "style": "yellow" },
        { "type": "context_bar", "format": "{used_percentage}%",      "style": "dim" }
      ]
    }
  }
}
