{
  "id": "python-dev",
  "version": "0.1.0",
  "title": {
    "ko": "Python 개발자",
    "en": "Python Developer"
  },
  "description": {
    "ko": "Python 환경 특화 — 가상환경명, Python 버전, 브랜치, 컨텍스트 상태",
    "en": "Python-focused — venv name, Python version, branch, and context state"
  },
  "tool": "ccstatusline",
  "category": "custom",
  "tags": [
    "python",
    "venv",
    "conda",
    "runtime"
  ],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "ccstatusline_settings": {
    "version": 3,
    "lines": [
      [
        {
          "id": "1",
          "type": "model",
          "color": "cyan",
          "bold": true
        },
        {
          "id": "2",
          "type": "custom-command",
          "color": "yellow",
          "commandPath": "basename $VIRTUAL_ENV",
          "bold": true
        },
        {
          "id": "3",
          "type": "custom-command",
          "color": "blue",
          "commandPath": "node --version"
        },
        {
          "id": "4",
          "type": "git-branch",
          "color": "green"
        },
        {
          "id": "5",
          "type": "context-bar",
          "color": "orange"
        },
        {
          "id": "6",
          "type": "session-cost",
          "color": "dim"
        }
      ]
    ]
  }
}
