      [
        {
          "id": "1",
          "type": "model",
          "color": "dim"
        },
        {
          "id": "2",
          "type": "context-bar",
          "color": "green"
        },
        {
          "id": "3",
          "type": "context-percentage",
          "color": "yellow"
        },
        {
          "id": "4",
          "type": "tokens-input",
          "color": "dim"
        },
        {
          "id": "5",
          "type": "tokens-output",
          "color": "dim"
        },
        {
          "id": "6",
          "type": "tokens-cached",
          "color": "cyan"
        }
      ]
    ]
  }
