{
  "id": "context-guardian",
  "version": "0.1.0",
  "title": {
    "ko": "컨텍스트 가디언",
    "en": "Context Guardian"
  },
  "description": {
    "ko": "컨텍스트 창 상태를 중심으로 — 사용량 바, %, 토큰 수, 남은 캐시를 실시간 모니터링",
    "en": "Context window health first — usage bar, %, token count, and cache savings live"
  },
  "tool": "ccstatusline",
  "category": "productivity",
  "tags": [
    "context",
    "tokens",
    "cache",
    "monitor"
  ],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
