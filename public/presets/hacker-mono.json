{
  "id": "hacker-mono",
  "version": "0.1.0",
  "title": {
    "ko": "해커 모노",
    "en": "Hacker Mono"
  },
  "description": {
    "ko": "단색 그린 해커 미학 — 심볼과 단축 표기로 정보 밀도를 극대화",
    "en": "Monochrome green hacker aesthetic — max info density with symbols and shorthand"
  },
  "tool": "ccstatusline",
  "category": "minimal",
  "tags": [
    "hacker",
    "mono",
    "green",
    "dense"
  ],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "ccstatusline_settings": {
    "version": 3,
    "lines": [
      [
        {
          "id": "1",
          "type": "model",
          "color": "green",
          "bold": true
        },
        {
          "id": "2",
          "type": "current-working-dir",
          "color": "green"
        },
        {
          "id": "3",
          "type": "git-branch",
          "color": "green"
        },
        {
          "id": "4",
          "type": "context-bar",
          "color": "green"
        },
        {
          "id": "5",
          "type": "session-cost",
          "color": "green"
        },
        {
          "id": "6",
          "type": "session-clock",
          "color": "green"
        }
      ]
    ]
  }
}
