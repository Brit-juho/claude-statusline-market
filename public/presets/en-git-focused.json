{
  "id": "en-git-focused",
  "version": "0.1.0",
  "title": {
    "ko": "Git 포커스",
    "en": "Git Focused"
  },
  "description": {
    "ko": "Git 상태를 중심으로 — 브랜치, 변경 파일 수, 커밋 수를 강조 표시",
    "en": "Git-centric view — highlights branch, changed file count, and ahead/behind commits"
  },
  "tool": "ccstatusline",
  "category": "git",
  "tags": [
    "git",
    "branch",
    "version-control"
  ],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "ccstatusline_settings": {
    "version": 3,
    "lines": [
      [
        {
          "id": "1",
          "type": "git-status",
          "color": "cyan",
          "bold": true
        },
        {
          "id": "2",
          "type": "git-changes",
          "color": "yellow"
        },
        {
          "id": "3",
          "type": "model",
          "color": "dim"
        },
        {
          "id": "4",
          "type": "session-cost",
          "color": "dim"
        }
      ]
    ]
  }
}
