{
  "id": "neo-clean-pro",
  "version": "0.1.0",
  "title": { "ko": "클린 프로", "en": "Clean Pro" },
  "description": {
    "ko": "군더더기 없는 프로페셔널 스타일 — 모델, 경로, 비용, 세션 시간만 담백하게",
    "en": "No-noise professional style — model, path, cost, session time. Nothing else"
  },
  "tool": "ccstatusline",
  "category": "minimal",
  "tags": ["clean", "professional", "minimal", "colors"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "   ",
      "segments": [
        { "type": "model",    "format": "{model}",                  "style": "white bold" },
        { "type": "cwd",      "format": "{cwd}",                    "style": "blue" },
        { "type": "cost",     "format": "${total_cost_usd:.4f}",    "style": "yellow" },
        { "type": "duration", "format": "{duration}",               "style": "dim" }
      ]
    }
  }
}
