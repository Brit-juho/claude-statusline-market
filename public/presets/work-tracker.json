{
  "id": "work-tracker",
  "version": "0.1.0",
  "title": {
    "ko": "작업 트래커",
    "en": "Work Tracker"
  },
  "description": {
    "ko": "개발 생산성 추적 — 경과 시간, 코드 변경량, Git 상태, 컨텍스트 사용률",
    "en": "Dev productivity tracking — elapsed time, code delta, Git state, context usage"
  },
  "tool": "ccstatusline",
  "category": "productivity",
  "tags": [
    "productivity",
    "time",
    "git",
    "lines"
  ],
  "author": {
    "name": "neo",
    "github": "NeTrioGit"
  },
  "ccstatusline_settings": {
    "version": 3,
    "lines": [
      [
        {
          "id": "1",
          "type": "session-clock",
          "color": "cyan"
        },
        {
          "id": "2",
          "type": "git-branch",
          "color": "green"
        },
        {
          "id": "3",
          "type": "git-changes",
          "color": "yellow"
        },
        {
          "id": "4",
          "type": "context-bar",
          "color": "dim"
        },
        {
          "id": "5",
          "type": "model",
          "color": "dim"
        }
      ]
    ]
  }
}
