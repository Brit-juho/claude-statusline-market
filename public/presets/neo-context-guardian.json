{
  "id": "neo-context-guardian",
  "version": "0.1.0",
  "title": { "ko": "컨텍스트 가디언", "en": "Context Guardian" },
  "description": {
    "ko": "컨텍스트 창 상태를 중심으로 — 사용량 바, %, 토큰 수, 남은 캐시를 실시간 모니터링",
    "en": "Context window health first — usage bar, %, token count, and cache savings live"
  },
  "tool": "ccstatusline",
  "category": "productivity",
  "tags": ["context", "tokens", "cache", "monitor"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  ",
      "segments": [
        { "type": "model",         "format": "{model}",                         "style": "dim" },
        { "type": "context_bar",   "format": "{used_percentage}%",              "style": "green" },
        { "type": "context_pct",   "format": "{used_percentage}% / {remaining_percentage}% left", "style": "yellow" },
        { "type": "tokens_in_out", "format": "↑{total_input_tokens} ↓{total_output_tokens}", "style": "dim" },
        { "type": "cache_tokens",  "format": "⚡{cache_saved_tokens} saved",   "style": "cyan" }
      ]
    }
  }
}
