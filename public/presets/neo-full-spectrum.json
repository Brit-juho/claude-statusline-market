{
  "id": "neo-full-spectrum",
  "version": "0.1.0",
  "title": { "ko": "풀 스펙트럼", "en": "Full Spectrum" },
  "description": {
    "ko": "모든 주요 정보를 무지개 색상으로 — 2줄 출력으로 정보 과부하 없이 전부 표시",
    "en": "All key info in rainbow colors — 2-line output showing everything without overload"
  },
  "tool": "ccstatusline",
  "category": "powerline",
  "tags": ["full", "colors", "rainbow", "multiline"],
  "author": { "name": "neo", "github": "NeTrioGit" },
  "settings": {
    "statusline": {
      "enabled": true,
      "position": "bottom",
      "separator": "  ",
      "segments": [
        { "type": "model",        "format": "◆ {model}",              "style": "cyan bold" },
        { "type": "cwd",          "format": "{dir_name}",              "style": "blue" },
        { "type": "git_branch",   "format": "⎇ {branch}",             "style": "green" },
        { "type": "context_pct",  "format": "{used_percentage}%",      "style": "yellow" },
        { "type": "cost",         "format": "${total_cost_usd:.4f}",   "style": "orange" },
        { "type": "duration",     "format": "◷ {duration}",            "style": "magenta" },
        { "type": "rate_5h",      "format": "5h:{rate_limit_5h}%",     "style": "red" }
      ]
    }
  }
}
