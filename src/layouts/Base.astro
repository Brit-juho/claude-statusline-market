---
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/index.ts';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title, description } = Astro.props;

const rawBase = import.meta.env.BASE_URL as string;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const pageTitle = title ? `${title} — ${t('site.title')}` : t('site.title');
const pageDescription = description ?? t('site.description');

const enHref = lang === 'ko'
  ? Astro.url.pathname.replace(/^\/ko/, '/en') || '/en'
  : Astro.url.pathname;
const koHref = lang === 'en'
  ? Astro.url.pathname.replace(/^\/en/, '') || '/'
  : Astro.url.pathname;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#0a0a0a" />
</head>
<body>
  <header class="header">
    <div class="header-inner">
      <a href={base || '/'} class="logo">
        <span class="logo-mark">◆</span>
        <span class="logo-text">Statusline Market</span>
      </a>
      <nav class="nav">
        <a href={lang === 'en' ? `${base}en/` : base || '/'} class="nav-link">{t('nav.gallery')}</a>
        <a href={lang === 'en' ? `${base}en/about` : `${base}about`} class="nav-link">{t('nav.about')}</a>
        <a href="https://github.com/NeTrioGit/claude-statusline-market" class="nav-link" target="_blank" rel="noopener">GitHub</a>
        <div class="lang-switcher">
          <a href={koHref} class:list={['lang-btn', { active: lang === 'ko' }]}>KR</a>
          <a href={enHref} class:list={['lang-btn', { active: lang === 'en' }]}>EN</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <p class="footer-copy">
        {t('footer.description')} &mdash; MIT License
      </p>
      <p class="footer-credit">
        {t('footer.made_with')} ♥ {t('footer.by')}
        <a href="https://github.com/NeTrioGit" target="_blank" rel="noopener">@NeTrioGit</a>
      </p>
    </div>
  </footer>
</body>
</html>

<style>
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid var(--border);
  background: rgba(10, 10, 10, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 600;
  font-size: 0.9375rem;
  letter-spacing: -0.02em;
}
.logo-mark { color: var(--accent); font-size: 0.75rem; }
.nav {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}
.nav-link {
  padding: 0.375rem 0.625rem;
  border-radius: var(--radius);
  font-size: 0.875rem;
  color: var(--text-dim);
  transition: color 0.15s, background 0.15s;
}
.nav-link:hover { color: var(--text); background: var(--bg-hover); }
.lang-switcher {
  display: flex;
  align-items: center;
  margin-left: 0.5rem;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.lang-btn {
  padding: 0.25rem 0.625rem;
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--text-dim);
  transition: color 0.15s, background 0.15s;
}
.lang-btn:hover { color: var(--text); background: var(--bg-hover); }
.lang-btn.active { color: var(--accent); background: var(--accent-dim); }
.footer {
  border-top: 1px solid var(--border);
  margin-top: 6rem;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.footer-copy, .footer-credit {
  font-size: 0.8125rem;
  color: var(--text-dim);
}
.footer-credit a { color: var(--accent); }
.footer-credit a:hover { text-decoration: underline; }
</style>
