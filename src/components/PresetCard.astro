---
import type { Lang } from '../i18n/index.ts';

interface Props {
  id: string;
  title: { ko: string; en: string };
  description: { ko: string; en: string };
  category: string;
  tags: string[];
  tool: string;
  lang: Lang;
  base: string;
}

const { id, title, description, category, tags, lang, base } = Astro.props;
const t_title = title[lang] ?? title.ko;
const t_desc = description[lang] ?? description.ko;
const href = lang === 'en' ? `${base}en/presets/${id}` : `${base}presets/${id}`;
const categoryLabel: Record<string, { ko: string; en: string }> = {
  minimal:      { ko: '미니멀', en: 'Minimal' },
  productivity: { ko: '생산성', en: 'Productivity' },
  cost:         { ko: '비용 추적', en: 'Cost Tracking' },
  git:          { ko: 'Git', en: 'Git' },
  powerline:    { ko: '파워라인', en: 'Powerline' },
  custom:       { ko: '커스텀', en: 'Custom' },
};
const catLabel = categoryLabel[Astro.props.category]?.[lang] ?? Astro.props.category;
---
<a href={href} class="card">
  <div class="card-meta">
    <span class="badge">{catLabel}</span>
  </div>
  <div class="card-screenshot" aria-hidden="true">
    <div class="mock-terminal">
      <div class="mock-bar">
        <span></span><span></span><span></span>
      </div>
      <div class="mock-content">
        <span class="mock-prompt">$ </span>
        <span class="mock-cursor"></span>
      </div>
      <div class="mock-statusline">
        <span class="mock-id">{id}</span>
      </div>
    </div>
  </div>
  <div class="card-body">
    <h3 class="card-title">{t_title}</h3>
    <p class="card-desc">{t_desc}</p>
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 3).map(tag => <span class="tag">#{tag}</span>)}
      </div>
    )}
  </div>
</a>

<style>
.card {
  display: flex;
  flex-direction: column;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: border-color 0.2s, transform 0.2s;
  cursor: pointer;
}
.card:hover {
  border-color: var(--border-hover);
  transform: translateY(-2px);
}
.card-meta {
  padding: 0.875rem 1rem 0;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.badge {
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-dim);
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
}
.card-screenshot {
  margin: 0.75rem 1rem;
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid var(--border);
}
.mock-terminal {
  background: #0d0d0d;
  font-family: var(--font-mono);
  font-size: 0.75rem;
}
.mock-bar {
  display: flex;
  gap: 5px;
  padding: 6px 8px;
  border-bottom: 1px solid var(--border);
}
.mock-bar span {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--border);
}
.mock-bar span:nth-child(1) { background: #ff5f57; }
.mock-bar span:nth-child(2) { background: #febc2e; }
.mock-bar span:nth-child(3) { background: #28c840; }
.mock-content {
  padding: 8px 10px 4px;
  color: var(--text-dim);
  min-height: 28px;
}
.mock-prompt { color: var(--accent); }
.mock-cursor {
  display: inline-block;
  width: 7px; height: 13px;
  background: var(--text-dim);
  vertical-align: text-bottom;
  animation: blink 1.2s step-end infinite;
}
@keyframes blink { 50% { opacity: 0; } }
.mock-statusline {
  padding: 4px 10px;
  background: #161616;
  border-top: 1px solid var(--border);
  color: var(--accent);
  font-size: 0.6875rem;
  display: flex;
  gap: 1rem;
}
.mock-id { opacity: 0.6; }
.card-body { padding: 0.5rem 1rem 1rem; }
.card-title {
  font-size: 0.9375rem;
  font-weight: 600;
  letter-spacing: -0.01em;
  margin-bottom: 0.375rem;
  color: var(--text);
}
.card-desc {
  font-size: 0.8125rem;
  color: var(--text-dim);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-tags {
  margin-top: 0.75rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
}
.tag {
  font-size: 0.6875rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
}
</style>
