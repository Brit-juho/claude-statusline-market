---
import type { Lang } from '../i18n/index.ts';
import { renderSegments, tokenBar, SAMPLE_VALUES } from '../lib/preview.ts';

interface Props {
  id: string;
  title: { ko: string; en: string };
  description: { ko: string; en: string };
  category: string;
  tags: string[];
  tool: string;
  lang: Lang;
  base: string;
  segments: Array<{ type: string; format?: string; enabled?: boolean }>;
  separator?: string;
}

const { id, title, description, category, tags, lang, base, segments, separator = '  ' } = Astro.props;
const t_title = title[lang] ?? title.ko;
const t_desc = description[lang] ?? description.ko;
const href = lang === 'en' ? `${base}en/presets/${id}` : `${base}presets/${id}`;

// 실제 렌더링된 세그먼트
const rendered = renderSegments(segments);
const cachePct = SAMPLE_VALUES.cache_hit_rate as number;
const hasCache = segments.some(s => s.type === 'cache');
const bar = hasCache ? tokenBar(cachePct) : null;

const categoryLabel: Record<string, { ko: string; en: string }> = {
  minimal:      { ko: '미니멀', en: 'Minimal' },
  productivity: { ko: '생산성', en: 'Productivity' },
  cost:         { ko: '비용 추적', en: 'Cost' },
  git:          { ko: 'Git', en: 'Git' },
  powerline:    { ko: '파워라인', en: 'Powerline' },
  custom:       { ko: '커스텀', en: 'Custom' },
};
const catLabel = categoryLabel[category]?.[lang] ?? category;
---
<a href={href} class="card">
  <!-- 터미널 미리보기: statusline이 주인공 -->
  <div class="card-preview">
    <div class="term-chrome">
      <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
      <span class="term-id">{id}</span>
    </div>
    <!-- 실제 statusline을 크게 보여줌 -->
    <div class="term-statusline">
      <div class="sl-segments">
        {rendered.map((seg, i) => (
          <span class:list={['sl-seg', i === 0 && 'sl-first']}>
            {i > 0 && <span class="sl-sep">{separator.trim() || '|'}</span>}
            {seg}
          </span>
        ))}
      </div>
      {bar && (
        <div class="sl-bar-row">
          <span class="sl-bar">{bar}</span>
          <span class="sl-bar-pct">{cachePct.toFixed(0)}%</span>
        </div>
      )}
    </div>
    <!-- 미니 프롬프트 힌트 -->
    <div class="term-prompt-line">
      <span class="prompt-text">~/project</span>
      <span class="prompt-dim"> $ claude ▌</span>
    </div>
  </div>

  <!-- 카드 정보 -->
  <div class="card-body">
    <div class="card-meta">
      <span class="badge">{catLabel}</span>
      {tags.slice(0, 2).map(tag => <span class="tag">#{tag}</span>)}
    </div>
    <h3 class="card-title">{t_title}</h3>
    <p class="card-desc">{t_desc}</p>
  </div>
</a>

<style>
.card {
  display: flex;
  flex-direction: column;
  background: #0f0f0f;
  border: 1px solid #1c1c1c;
  border-radius: 10px;
  overflow: hidden;
  transition: border-color 0.2s, transform 0.18s, box-shadow 0.2s;
  cursor: pointer;
  text-decoration: none;
}
.card:hover {
  border-color: #2e2e2e;
  transform: translateY(-3px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}
/* ─── 터미널 미리보기 ─── */
.card-preview {
  background: #0d0d0d;
  border-bottom: 1px solid #1c1c1c;
  font-family: var(--font-mono);
}
.term-chrome {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 7px 11px;
  border-bottom: 1px solid #181818;
}
.dot { width: 8px; height: 8px; border-radius: 50%; }
.dot.r { background: #ff5f57; }
.dot.y { background: #febc2e; }
.dot.g { background: #28c840; }
.term-id {
  margin-left: 6px;
  font-size: 0.65rem;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
/* ─── statusline 메인 표시 영역 ─── */
.term-statusline {
  padding: 0.875rem 1rem 0.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.sl-segments {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0;
  font-size: 0.8125rem;
  line-height: 1.5;
}
.sl-seg {
  display: inline-flex;
  align-items: center;
  color: var(--accent);
  white-space: nowrap;
}
.sl-first {
  font-weight: 500;
}
.sl-sep {
  color: #2e2e2e;
  margin: 0 0.4rem;
  font-size: 0.75rem;
}
.sl-bar-row {
  display: flex;
  align-items: center;
  gap: 0.375rem;
}
.sl-bar {
  font-size: 0.7rem;
  color: #2a6645;
  letter-spacing: -0.5px;
}
.sl-bar-pct {
  font-size: 0.7rem;
  color: #3a8a5a;
}
/* ─── 하단 프롬프트 힌트 ─── */
.term-prompt-line {
  padding: 0.25rem 1rem 0.625rem;
  font-size: 0.7rem;
}
.prompt-text { color: #2a6645; }
.prompt-dim { color: #282828; }
/* ─── 카드 본문 ─── */
.card-body { padding: 0.875rem 1rem 1rem; }
.card-meta {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  margin-bottom: 0.45rem;
  flex-wrap: wrap;
}
.badge {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-dim);
  padding: 0.15rem 0.45rem;
  border-radius: 3px;
}
.tag { font-size: 0.65rem; color: #383838; font-family: var(--font-mono); }
.card-title {
  font-size: 0.9375rem;
  font-weight: 600;
  letter-spacing: -0.02em;
  margin-bottom: 0.3rem;
  color: var(--text);
}
.card-desc {
  font-size: 0.8125rem;
  color: var(--text-dim);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style>
