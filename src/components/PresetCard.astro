---
import type { Lang } from '../i18n/index.ts';
import { renderSegments, tokenBar, SAMPLE_VALUES } from '../lib/preview.ts';

interface Props {
  id: string;
  title: { ko: string; en: string };
  description: { ko: string; en: string };
  category: string;
  tags: string[];
  tool: string;
  lang: Lang;
  base: string;
  segments: Array<{ type: string; format?: string; enabled?: boolean }>;
  separator?: string;
}

const { id, title, description, category, tags, lang, base, segments, separator = '  ' } = Astro.props;
const t_title = title[lang] ?? title.ko;
const t_desc = description[lang] ?? description.ko;
const href = lang === 'en' ? `${base}en/presets/${id}` : `${base}presets/${id}`;

const rendered = renderSegments(segments);
const statusline = rendered.join(separator);

const hasCache = segments.some(s => s.type === 'cache');
const cachePct = SAMPLE_VALUES.cache_hit_rate as number;
const bar = hasCache ? tokenBar(cachePct) : null;

const categoryLabel: Record<string, { ko: string; en: string }> = {
  minimal:      { ko: '미니멀', en: 'Minimal' },
  productivity: { ko: '생산성', en: 'Productivity' },
  cost:         { ko: '비용 추적', en: 'Cost' },
  git:          { ko: 'Git', en: 'Git' },
  powerline:    { ko: '파워라인', en: 'Powerline' },
  custom:       { ko: '커스텀', en: 'Custom' },
};
const catLabel = categoryLabel[category]?.[lang] ?? category;
---
<a href={href} class="card">
  <div class="card-terminal">
    <div class="term-bar">
      <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
      <span class="term-title">{id}</span>
    </div>
    <div class="term-body">
      <div class="term-line"><span class="term-prompt">~/project</span> <span class="term-dim">$</span> claude</div>
      <div class="term-line term-dim">▶ Analyzing changes...</div>
    </div>
    <div class="term-status">
      <span class="status-text">{statusline}</span>
      {bar && <span class="status-bar">{bar} {cachePct.toFixed(0)}%</span>}
    </div>
  </div>
  <div class="card-body">
    <div class="card-meta">
      <span class="badge">{catLabel}</span>
      {tags.slice(0, 2).map(tag => <span class="tag">#{tag}</span>)}
    </div>
    <h3 class="card-title">{t_title}</h3>
    <p class="card-desc">{t_desc}</p>
  </div>
</a>

<style>
.card {
  display: flex;
  flex-direction: column;
  background: #0f0f0f;
  border: 1px solid #1a1a1a;
  border-radius: 10px;
  overflow: hidden;
  transition: border-color 0.2s, transform 0.18s;
  cursor: pointer;
  text-decoration: none;
}
.card:hover {
  border-color: #2a2a2a;
  transform: translateY(-3px);
}
.card-terminal {
  background: #0d0d0d;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  border-bottom: 1px solid #1a1a1a;
}
.term-bar {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 7px 10px;
  border-bottom: 1px solid #1a1a1a;
}
.dot {
  width: 9px; height: 9px;
  border-radius: 50%;
}
.dot.r { background: #ff5f57; }
.dot.y { background: #febc2e; }
.dot.g { background: #28c840; }
.term-title {
  margin-left: 6px;
  color: #444;
  font-size: 0.6875rem;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.term-body {
  padding: 8px 12px 6px;
  min-height: 42px;
}
.term-line {
  line-height: 1.65;
  color: #888;
}
.term-dim { color: #444; }
.term-prompt { color: var(--accent); }
.term-status {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4px 12px 5px;
  background: #111;
  border-top: 1px solid #1a1a1a;
  gap: 0.75rem;
  min-height: 24px;
}
.status-text {
  color: var(--accent);
  font-size: 0.7rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}
.status-bar {
  color: #555;
  font-size: 0.65rem;
  white-space: nowrap;
  flex-shrink: 0;
}
.card-body {
  padding: 0.875rem 1rem 1rem;
}
.card-meta {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  margin-bottom: 0.5rem;
  flex-wrap: wrap;
}
.badge {
  font-size: 0.625rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-dim);
  padding: 0.15rem 0.45rem;
  border-radius: 3px;
}
.tag {
  font-size: 0.65rem;
  color: #444;
  font-family: var(--font-mono);
}
.card-title {
  font-size: 0.9375rem;
  font-weight: 600;
  letter-spacing: -0.02em;
  margin-bottom: 0.3rem;
  color: var(--text);
}
.card-desc {
  font-size: 0.8125rem;
  color: var(--text-dim);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style>
