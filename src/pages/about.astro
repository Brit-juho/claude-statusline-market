---
import Base from '../layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '../i18n/index.ts';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<Base title={t('about.title')}>
  <div class="about-layout">
    <div class="about-inner">
      <h1 class="about-title">{t('about.title')}</h1>

      <section class="about-section">
        <h2>{t('about.what')}</h2>
        <p>{t('about.what_desc')}</p>
      </section>

      <section class="about-section">
        <h2>{t('about.contribute')}</h2>
        <p>{t('about.contribute_desc')}</p>
        <div class="steps">
          <div class="step">
            <span class="step-num">1</span>
            <div>
              <strong>{lang === 'ko' ? 'Fork & 프리셋 작성' : 'Fork & write a preset'}</strong>
              <p>{lang === 'ko'
                ? 'presets/ 폴더에 JSON 파일을 추가하세요. schema.json을 참고해 필드를 채우세요.'
                : 'Add a JSON file to the presets/ folder. Fill in fields following schema.json.'}</p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">2</span>
            <div>
              <strong>PR {lang === 'ko' ? '열기' : 'Open'}</strong>
              <p>{lang === 'ko'
                ? 'Pull Request를 열면 CI가 자동으로 스크린샷을 생성하고 schema를 검증합니다.'
                : 'Open a Pull Request — CI auto-validates the schema and generates screenshots.'}</p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">3</span>
            <div>
              <strong>{lang === 'ko' ? '갤러리에 게시' : 'Published to Gallery'}</strong>
              <p>{lang === 'ko'
                ? 'Merge되면 갤러리에 즉시 반영됩니다.'
                : 'Once merged, it appears in the gallery immediately.'}</p>
            </div>
          </div>
        </div>
        <a href="https://github.com/NeTrioGit/claude-statusline-market" target="_blank" rel="noopener" class="gh-btn">
          GitHub {lang === 'ko' ? '에서 기여하기' : '— Contribute'}
        </a>
      </section>
    </div>
  </div>
</Base>

<style>
.about-layout { padding: 4rem 1.5rem; }
.about-inner { max-width: 680px; margin: 0 auto; }
.about-title { font-size: 2rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 2.5rem; }
.about-section { margin-bottom: 3rem; }
.about-section h2 { font-size: 1.125rem; font-weight: 600; margin-bottom: 0.75rem; }
.about-section p { color: var(--text-dim); line-height: 1.7; font-size: 0.9375rem; }
.steps { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.step { display: flex; gap: 1rem; align-items: flex-start; }
.step-num {
  flex-shrink: 0; width: 28px; height: 28px;
  border-radius: 50%; background: var(--accent-dim);
  color: var(--accent); font-size: 0.8125rem; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.step strong { display: block; font-size: 0.9375rem; margin-bottom: 0.25rem; }
.step p { font-size: 0.875rem; color: var(--text-dim); }
.gh-btn {
  display: inline-block; margin-top: 1.5rem;
  padding: 0.625rem 1.25rem;
  background: var(--accent); color: #000;
  border-radius: var(--radius); font-size: 0.875rem; font-weight: 600;
  transition: opacity 0.15s;
}
.gh-btn:hover { opacity: 0.88; }
</style>
