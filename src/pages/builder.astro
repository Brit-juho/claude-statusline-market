---
import Base from '../layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '../i18n/index.ts';
import { getAllPresets } from '../lib/presets.ts';
import { SAMPLE_VALUES } from '../lib/preview.ts';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const presets = await getAllPresets();
const rawBase = import.meta.env.BASE_URL as string;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

/* ─────────────────────────────────────────────────────────────
   세그먼트 정의: 공식 문서 기반 전체 필드
   각 style: { emoji, symbol, plain }
───────────────────────────────────────────────────────────── */
const SEGMENT_GROUPS = [
  {
    group: lang === 'ko' ? '모델 / 세션' : 'Model / Session',
    segments: [
      {
        type: 'model', label: { ko: '모델명', en: 'Model' },
        styles: {
          emoji:   { label: '◆ Sonnet 4.6',  fmt: '◆ {model}' },
          symbol:  { label: '▶ Sonnet 4.6',  fmt: '▶ {model}' },
          plain:   { label: 'Sonnet 4.6',    fmt: '{model}' },
        },
        extras: [
          { label: '[Sonnet 4.6]',    fmt: '[{model}]' },
          { label: 'model:Sonnet 4.6', fmt: 'model:{model}' },
        ],
      },
      {
        type: 'version', label: { ko: 'CC 버전', en: 'CC Version' },
        styles: {
          emoji:   { label: '🔖 v2.1.90', fmt: '🔖 v{version}' },
          symbol:  { label: '◇ v2.1.90',  fmt: '◇ v{version}' },
          plain:   { label: 'v2.1.90',     fmt: 'v{version}' },
        },
        extras: [],
      },
      {
        type: 'session_id', label: { ko: '세션 ID', en: 'Session ID' },
        styles: {
          emoji:   { label: '🆔 abc123de', fmt: '🆔 {session_id}' },
          symbol:  { label: '# abc123de',  fmt: '#{session_id}' },
          plain:   { label: 'abc123de',    fmt: '{session_id}' },
        },
        extras: [
          { label: 'sid:abc123de', fmt: 'sid:{session_id}' },
        ],
      },
      {
        type: 'session_name', label: { ko: '세션명', en: 'Session Name' },
        styles: {
          emoji:   { label: '📌 my-session', fmt: '📌 {session_name}' },
          symbol:  { label: '▪ my-session',  fmt: '▪ {session_name}' },
          plain:   { label: 'my-session',    fmt: '{session_name}' },
        },
        extras: [],
      },
      {
        type: 'effort', label: { ko: '추론 수준', en: 'Effort' },
        styles: {
          emoji:   { label: '🧠 high',    fmt: '🧠 {effort_level}' },
          symbol:  { label: '● high',    fmt: '● {effort_level}' },
          plain:   { label: 'effort:high', fmt: 'effort:{effort_level}' },
        },
        extras: [
          { label: 'E:high', fmt: 'E:{effort_level}' },
        ],
      },
    ],
  },
  {
    group: lang === 'ko' ? '작업 공간' : 'Workspace',
    segments: [
      {
        type: 'cwd', label: { ko: '현재 디렉터리', en: 'Current Dir' },
        styles: {
          emoji:   { label: '📁 ~/GitHub/my-project', fmt: '📁 {cwd}' },
          symbol:  { label: '◆ ~/GitHub/my-project',  fmt: '◆ {cwd}' },
          plain:   { label: '~/GitHub/my-project',     fmt: '{cwd}' },
        },
        extras: [
          { label: 'my-project',         fmt: '{dir_name}' },
          { label: 'dir:~/GitHub/my-project', fmt: 'dir:{cwd}' },
        ],
      },
      {
        type: 'git_branch', label: { ko: 'Git 브랜치', en: 'Git Branch' },
        styles: {
          emoji:   { label: '🌿 main',    fmt: '🌿 {branch}' },
          symbol:  { label: '⎇ main',    fmt: '⎇ {branch}' },
          plain:   { label: 'main',      fmt: '{branch}' },
        },
        extras: [
          { label: '(main)',             fmt: '({branch})' },
          { label: 'main ↑0 ↓0',       fmt: '{branch} ↑{ahead} ↓{behind}' },
          { label: 'git:main',           fmt: 'git:{branch}' },
        ],
      },
      {
        type: 'git_changes', label: { ko: '변경 파일', en: 'Changes' },
        styles: {
          emoji:   { label: '✏️ 3 changed',  fmt: '✏️ {changed} changed' },
          symbol:  { label: '~ 3 changed',   fmt: '~{changed}' },
          plain:   { label: '3 changed',     fmt: '{changed} changed' },
        },
        extras: [
          { label: 'Δ3',                fmt: 'Δ{changed}' },
          { label: '+156 -23',           fmt: '+{total_lines_added} -{total_lines_removed}' },
        ],
      },
    ],
  },
  {
    group: lang === 'ko' ? '컨텍스트 창' : 'Context Window',
    segments: [
      {
        type: 'context_pct', label: { ko: '컨텍스트 %', en: 'Context %' },
        styles: {
          emoji:   { label: '📊 12%',    fmt: '📊 {used_percentage}%' },
          symbol:  { label: '◉ 12%',    fmt: '◉ {used_percentage}%' },
          plain:   { label: '12% ctx',   fmt: '{used_percentage}% ctx' },
        },
        extras: [
          { label: 'used:12% rem:88%',   fmt: 'used:{used_percentage}% rem:{remaining_percentage}%' },
          { label: '12%/200k',           fmt: '{used_percentage}%/{context_window_size}' },
        ],
      },
      {
        type: 'context_bar', label: { ko: '컨텍스트 바', en: 'Context Bar' },
        styles: {
          emoji:   { label: '▓▓░░░░░░░░ 12%', fmt: '[CTX:{used_percentage}%]' },
          symbol:  { label: '▓▓░░░░░░░░ 12%', fmt: '[CTX:{used_percentage}%]' },
          plain:   { label: 'ctx:12%',          fmt: 'ctx:{used_percentage}%' },
        },
        extras: [],
      },
      {
        type: 'tokens_in_out', label: { ko: '입출력 토큰', en: 'In/Out Tokens' },
        styles: {
          emoji:   { label: '🔢 in:15234 out:4521', fmt: '🔢 in:{total_input_tokens} out:{total_output_tokens}' },
          symbol:  { label: '↕ 15234/4521',          fmt: '↕{total_input_tokens}/{total_output_tokens}' },
          plain:   { label: 'in:15234 out:4521',      fmt: 'in:{total_input_tokens} out:{total_output_tokens}' },
        },
        extras: [
          { label: '15234+4521',   fmt: '{total_input_tokens}+{total_output_tokens}' },
          { label: '19755tok',     fmt: '{total_tokens}tok' },
        ],
      },
      {
        type: 'cache_tokens', label: { ko: '캐시 토큰', en: 'Cache Tokens' },
        styles: {
          emoji:   { label: '⚡ saved:8912',    fmt: '⚡ saved:{cache_saved_tokens}' },
          symbol:  { label: '◈ saved:8912',     fmt: '◈ saved:{cache_saved_tokens}' },
          plain:   { label: 'saved:8912',        fmt: 'saved:{cache_saved_tokens}' },
        },
        extras: [
          { label: 'C:87%',                fmt: 'C:{cache_hit_rate:.0f}%' },
          { label: 'CACHE 87%',            fmt: 'CACHE {cache_hit_rate:.0f}%' },
          { label: 'cache:87.3%',          fmt: 'cache:{cache_hit_rate:.1f}%' },
        ],
      },
    ],
  },
  {
    group: lang === 'ko' ? '비용 / 시간' : 'Cost / Time',
    segments: [
      {
        type: 'cost', label: { ko: '세션 비용', en: 'Session Cost' },
        styles: {
          emoji:   { label: '💰 $0.0234',    fmt: '💰 ${total_cost_usd:.4f}' },
          symbol:  { label: '$ $0.0234',     fmt: '$ ${total_cost_usd:.4f}' },
          plain:   { label: '$0.0234',        fmt: '${total_cost_usd:.4f}' },
        },
        extras: [
          { label: '$0.02',           fmt: '${total_cost_usd:.2f}' },
          { label: 'cost:$0.0234',    fmt: 'cost:${total_cost_usd:.4f}' },
        ],
      },
      {
        type: 'duration', label: { ko: '세션 시간', en: 'Duration' },
        styles: {
          emoji:   { label: '⏱ 1h 23m',        fmt: '⏱ {duration}' },
          symbol:  { label: '◷ 1h 23m',         fmt: '◷ {duration}' },
          plain:   { label: '1h 23m',            fmt: '{duration}' },
        },
        extras: [
          { label: 'session:1h 23m',   fmt: 'session:{duration}' },
        ],
      },
      {
        type: 'lines_changed', label: { ko: '코드 변경', en: 'Lines Changed' },
        styles: {
          emoji:   { label: '📝 +156 -23',   fmt: '📝 +{total_lines_added} -{total_lines_removed}' },
          symbol:  { label: '+156 -23',       fmt: '+{total_lines_added} -{total_lines_removed}' },
          plain:   { label: '+156 -23',       fmt: '+{total_lines_added} -{total_lines_removed}' },
        },
        extras: [],
      },
    ],
  },
  {
    group: lang === 'ko' ? '한도 / 시스템' : 'Limits / System',
    segments: [
      {
        type: 'rate_5h', label: { ko: '5h 한도', en: '5h Rate' },
        styles: {
          emoji:   { label: '🕐 5h:23%',    fmt: '🕐 5h:{rate_limit_5h}%' },
          symbol:  { label: '◷ 5h:23%',     fmt: '◷ 5h:{rate_limit_5h}%' },
          plain:   { label: '5h:23%',        fmt: '5h:{rate_limit_5h}%' },
        },
        extras: [],
      },
      {
        type: 'rate_7d', label: { ko: '7d 한도', en: '7d Rate' },
        styles: {
          emoji:   { label: '📅 7d:41%',    fmt: '📅 7d:{rate_limit_7d}%' },
          symbol:  { label: '◻ 7d:41%',     fmt: '◻ 7d:{rate_limit_7d}%' },
          plain:   { label: '7d:41%',        fmt: '7d:{rate_limit_7d}%' },
        },
        extras: [],
      },
      {
        type: 'vim_mode', label: { ko: 'Vim 모드', en: 'Vim Mode' },
        styles: {
          emoji:   { label: '⌨️ NORMAL',    fmt: '⌨️ {vim_mode}' },
          symbol:  { label: '▸ NORMAL',     fmt: '▸ {vim_mode}' },
          plain:   { label: 'NORMAL',        fmt: '{vim_mode}' },
        },
        extras: [{ label: '[NORMAL]', fmt: '[{vim_mode}]' }],
      },
    ],
  },
];

const sampleValuesJson = JSON.stringify(SAMPLE_VALUES);
const segmentGroupsJson = JSON.stringify(SEGMENT_GROUPS);
const presetsJson = JSON.stringify(presets.map(p => ({
  id: p.id,
  title: p.title,
  category: p.category,
  segments: p.settings.statusline.segments,
  separator: p.settings.statusline.separator ?? '  ',
})));
---
<Base title={lang === 'ko' ? '커스텀 빌더' : 'Custom Builder'}>
<div class="builder-layout">

  <div class="builder-header">
    <h1>{lang === 'ko' ? '커스텀 빌더' : 'Custom Builder'}</h1>
    <p>{lang === 'ko' ? '공식 필드 전체를 조합해 나만의 상태바를 만드세요.' : 'Combine all official fields to build your own statusbar.'}</p>
  </div>

  <!-- 프리셋 기반 시작 -->
  <div class="preset-start">
    <span class="start-label">{lang === 'ko' ? '프리셋에서 시작:' : 'Start from preset:'}</span>
    <div class="preset-chips" id="presetChips"></div>
  </div>

  <!-- 스타일 토글 -->
  <div class="style-toggle">
    <span class="start-label">{lang === 'ko' ? '아이콘 스타일:' : 'Icon style:'}</span>
    <div class="style-btns">
      <button class="style-btn active" data-style="emoji">{lang === 'ko' ? '이모지 🌿' : 'Emoji 🌿'}</button>
      <button class="style-btn" data-style="symbol">{lang === 'ko' ? '유니코드 ⎇' : 'Unicode ⎇'}</button>
      <button class="style-btn" data-style="plain">{lang === 'ko' ? '텍스트만' : 'Plain text'}</button>
    </div>
    <span class="style-hint">
      {lang === 'ko'
        ? '유니코드는 이모지 없이도 구분감을 줍니다 (◆ ▶ ⎇ ◷)'
        : 'Unicode gives visual rhythm without emoji (◆ ▶ ⎇ ◷)'}
    </span>
  </div>

  <div class="builder-main">
    <!-- 왼쪽: 세그먼트 팔레트 -->
    <div class="panel panel-left">
      <h2 class="panel-title">{lang === 'ko' ? '세그먼트 선택' : 'Select Segments'}</h2>
      <div id="segmentPalette"></div>
      <div class="separator-row">
        <label class="sep-label">{lang === 'ko' ? '구분자' : 'Separator'}</label>
        <input id="separatorInput" class="sep-input" type="text" value="  " maxlength="10" />
      </div>
    </div>

    <!-- 오른쪽: 활성 세그먼트 -->
    <div class="panel panel-right">
      <h2 class="panel-title">{lang === 'ko' ? '활성 세그먼트' : 'Active Segments'}</h2>
      <div class="active-list" id="activeList">
        <div class="empty-hint">{lang === 'ko' ? '왼쪽에서 세그먼트를 추가하세요' : 'Add segments from the left'}</div>
      </div>
    </div>
  </div>

  <!-- 터미널 미리보기 -->
  <div class="preview-section">
    <h2 class="panel-title">{lang === 'ko' ? '미리보기' : 'Preview'}</h2>
    <div class="preview-terminal">
      <div class="term-chrome">
        <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
        <span class="term-path">~/GitHub/my-project — bash</span>
      </div>
      <div class="term-body">
        <div class="term-line"><span class="term-acc">~/GitHub/my-project</span> <span class="term-dim">$</span> claude</div>
        <div class="term-line term-dim">▶ Analyzing changes...</div>
        <div class="term-line">&nbsp;</div>
        <div class="term-line term-dim">  3 files changed, 156 insertions(+), 23 deletions(-)</div>
      </div>
      <div class="term-status" id="livePreview">
        <span class="status-placeholder">{lang === 'ko' ? '세그먼트를 추가하면 여기 표시됩니다' : 'Add segments to see preview'}</span>
      </div>
    </div>
  </div>

  <!-- 출력 -->
  <div class="output-section">
    <div class="output-tabs">
      <button class="out-tab active" data-tab="install">{lang === 'ko' ? '설치 명령' : 'Install'}</button>
      <button class="out-tab" data-tab="json">JSON</button>
    </div>
    <div class="out-panel" id="panelInstall">
      <div class="install-label">macOS / Linux</div>
      <div class="code-row"><code class="code-block" id="installSh"></code><button class="copy-btn" id="copyInstallSh">{lang === 'ko' ? '복사' : 'Copy'}</button></div>
      <div class="install-label" style="margin-top:0.75rem">Windows (PowerShell)</div>
      <div class="code-row"><code class="code-block" id="installPs"></code><button class="copy-btn" id="copyInstallPs">{lang === 'ko' ? '복사' : 'Copy'}</button></div>
    </div>
    <div class="out-panel hidden" id="panelJson">
      <div class="code-row json-row"><pre class="code-block json-pre" id="jsonOutput"></pre><button class="copy-btn" id="copyJson">{lang === 'ko' ? '복사' : 'Copy'}</button></div>
    </div>
  </div>

</div>
</Base>

<script define:vars={{ sampleValuesJson, segmentGroupsJson, presetsJson, lang }}>
const VALS = JSON.parse(sampleValuesJson);
const GROUPS = JSON.parse(segmentGroupsJson);
const PRESETS = JSON.parse(presetsJson);

let activeSegments = [];
let separator = '  ';
let iconStyle = 'emoji'; // 'emoji' | 'symbol' | 'plain'

/* ── render ── */
function renderFmt(fmt) {
  return fmt.replace(/\{([a-zA-Z_.]+)(?::([^}]+))?\}/g, (_, key, spec) => {
    const v = VALS[key];
    if (v === undefined) return `{${key}}`;
    if (spec) {
      const m = spec.match(/\.(\d+)f/);
      if (m) return Number(v).toFixed(parseInt(m[1]));
    }
    return String(v);
  });
}

function getStatusline() {
  return activeSegments.map(s => renderFmt(s.format)).join(separator);
}

function tokenBar(pct, w = 12) {
  const f = Math.round((pct / 100) * w);
  return '▓'.repeat(f) + '░'.repeat(w - f);
}

/* ── live preview ── */
function updatePreview() {
  const el = document.getElementById('livePreview');
  if (!el) return;
  if (activeSegments.length === 0) {
    el.innerHTML = `<span class="status-placeholder">${lang === 'ko' ? '세그먼트를 추가하면 여기 표시됩니다' : 'Add segments to see preview'}</span>`;
    return;
  }
  const sl = getStatusline();
  const hasPct = activeSegments.some(s => s.type === 'context_bar' || s.type === 'context_pct');
  const bar = hasPct ? `<span class="preview-bar">${tokenBar(VALS.used_percentage, 10)}</span>` : '';
  el.innerHTML = `<span class="sline">${sl}</span>${bar}`;
}

/* ── output ── */
function buildJson() {
  return JSON.stringify({
    settings: {
      statusline: {
        enabled: true,
        position: 'bottom',
        separator,
        segments: activeSegments.map(s => ({ type: s.type, format: s.format })),
      },
    },
  }, null, 2);
}

function updateOutput() {
  const BASE = 'https://raw.githubusercontent.com/NeTrioGit/claude-statusline-market/main';
  const id = 'custom-' + Date.now().toString(36);
  document.getElementById('installSh').textContent = `curl -fsSL ${BASE}/scripts/install-preset.sh | bash -s -- ${id}`;
  document.getElementById('installPs').textContent = `irm ${BASE}/scripts/install-preset.ps1 | iex; Install-Preset ${id}`;
  document.getElementById('jsonOutput').textContent = buildJson();
}

/* ── active list ── */
function renderActiveList() {
  const el = document.getElementById('activeList');
  if (activeSegments.length === 0) {
    el.innerHTML = `<div class="empty-hint">${lang === 'ko' ? '왼쪽에서 세그먼트를 추가하세요' : 'Add segments from the left'}</div>`;
    return;
  }
  el.innerHTML = activeSegments.map((s, i) => {
    // find extras from groups
    let extras = [];
    for (const g of GROUPS) {
      const def = g.segments.find(d => d.type === s.type);
      if (def) {
        // style options + extras
        extras = [
          { label: def.styles.emoji.label,  fmt: def.styles.emoji.fmt },
          { label: def.styles.symbol.label, fmt: def.styles.symbol.fmt },
          { label: def.styles.plain.label,  fmt: def.styles.plain.fmt },
          ...(def.extras || []),
        ];
        break;
      }
    }
    const fmtOpts = extras.map(f => `
      <button class="fmt-opt ${s.format === f.fmt ? 'fmt-opt-active' : ''}"
              data-idx="${i}" data-fmt="${f.fmt.replace(/"/g, '&quot;')}">
        ${renderFmt(f.fmt)}
      </button>`).join('');
    return `
    <div class="active-item">
      <div class="active-header">
        <span class="active-type">${s.label}</span>
        <div class="active-btns">
          <button class="icon-btn" data-action="up" data-idx="${i}" ${i === 0 ? 'disabled' : ''}>↑</button>
          <button class="icon-btn" data-action="down" data-idx="${i}" ${i === activeSegments.length - 1 ? 'disabled' : ''}>↓</button>
          <button class="icon-btn rm" data-action="rm" data-idx="${i}">×</button>
        </div>
      </div>
      <div class="fmt-opts">${fmtOpts}</div>
      <div class="fmt-row">
        <input class="fmt-input" data-idx="${i}" value="${s.format.replace(/"/g, '&quot;')}" placeholder="포맷 직접 입력..." />
        <span class="fmt-preview">${renderFmt(s.format)}</span>
      </div>
    </div>`;
  }).join('');

  el.querySelectorAll('.fmt-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.idx);
      activeSegments[idx].format = btn.dataset.fmt;
      renderActiveList(); updatePreview(); updateOutput();
    });
  });
  el.querySelectorAll('.fmt-input').forEach(inp => {
    inp.addEventListener('input', e => {
      const idx = parseInt(e.target.dataset.idx);
      activeSegments[idx].format = e.target.value;
      const prev = inp.closest('.active-item')?.querySelector('.fmt-preview');
      if (prev) prev.textContent = renderFmt(e.target.value);
      inp.closest('.active-item')?.querySelectorAll('.fmt-opt').forEach(b => b.classList.remove('fmt-opt-active'));
      updatePreview(); updateOutput();
    });
  });
  el.querySelectorAll('.icon-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.idx);
      const action = btn.dataset.action;
      if (action === 'up' && idx > 0) [activeSegments[idx-1], activeSegments[idx]] = [activeSegments[idx], activeSegments[idx-1]];
      else if (action === 'down' && idx < activeSegments.length - 1) [activeSegments[idx], activeSegments[idx+1]] = [activeSegments[idx+1], activeSegments[idx]];
      else if (action === 'rm') activeSegments.splice(idx, 1);
      renderActiveList(); renderPalette(); updatePreview(); updateOutput();
    });
  });
}

/* ── palette ── */
function renderPalette() {
  const el = document.getElementById('segmentPalette');
  el.innerHTML = GROUPS.map(g => `
    <div class="seg-group">
      <div class="seg-group-label">${g.group}</div>
      <div class="seg-group-items">
        ${g.segments.map(seg => {
          const active = activeSegments.some(s => s.type === seg.type);
          const preview = renderFmt(seg.styles[iconStyle]?.fmt ?? seg.styles.plain.fmt);
          return `
          <button class="seg-btn ${active ? 'seg-active' : ''}" data-type="${seg.type}">
            <span class="seg-lbl">${seg.label[lang] ?? seg.label.ko}</span>
            <span class="seg-sample">${preview}</span>
            <span class="seg-toggle">${active ? '✓' : '+'}</span>
          </button>`;
        }).join('')}
      </div>
    </div>
  `).join('');

  el.querySelectorAll('.seg-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.type;
      const alreadyIdx = activeSegments.findIndex(s => s.type === type);
      if (alreadyIdx !== -1) {
        activeSegments.splice(alreadyIdx, 1);
      } else {
        let def = null;
        for (const g of GROUPS) { def = g.segments.find(s => s.type === type); if (def) break; }
        if (!def) return;
        const styleFmt = def.styles[iconStyle]?.fmt ?? def.styles.plain.fmt;
        activeSegments.push({
          type,
          format: styleFmt,
          label: def.label[lang] ?? def.label.ko,
        });
      }
      renderActiveList(); renderPalette(); updatePreview(); updateOutput();
    });
  });
}

/* ── preset chips ── */
function renderPresetChips() {
  const el = document.getElementById('presetChips');
  el.innerHTML = PRESETS.map(p => `
    <button class="preset-chip" data-id="${p.id}">${p.title[lang] ?? p.title.ko}</button>
  `).join('');
  el.querySelectorAll('.preset-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = PRESETS.find(x => x.id === btn.dataset.id);
      if (!p) return;
      separator = p.separator ?? '  ';
      document.getElementById('separatorInput').value = separator;
      activeSegments = p.segments.map(s => {
        let def = null;
        for (const g of GROUPS) { def = g.segments.find(d => d.type === s.type); if (def) break; }
        return {
          type: s.type,
          format: s.format ?? def?.styles[iconStyle]?.fmt ?? def?.styles?.plain?.fmt ?? s.type,
          label: def?.label?.[lang] ?? def?.label?.ko ?? s.type,
        };
      });
      renderActiveList(); renderPalette(); updatePreview(); updateOutput();
      el.querySelectorAll('.preset-chip').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
    });
  });
}

/* ── style toggle ── */
document.querySelectorAll('.style-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.style-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    iconStyle = btn.dataset.style;
    // 활성 세그먼트의 포맷도 같은 style로 업데이트
    activeSegments = activeSegments.map(s => {
      let def = null;
      for (const g of GROUPS) { def = g.segments.find(d => d.type === s.type); if (def) break; }
      if (!def) return s;
      return { ...s, format: def.styles[iconStyle]?.fmt ?? def.styles.plain.fmt };
    });
    renderActiveList(); renderPalette(); updatePreview(); updateOutput();
  });
});

/* ── separator ── */
document.getElementById('separatorInput')?.addEventListener('input', e => {
  separator = e.target.value;
  updatePreview(); updateOutput();
});

/* ── output tabs ── */
document.querySelectorAll('.out-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.out-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const which = tab.dataset.tab;
    document.getElementById('panelInstall').classList.toggle('hidden', which !== 'install');
    document.getElementById('panelJson').classList.toggle('hidden', which !== 'json');
  });
});

/* ── copy ── */
function setupCopy(btnId, srcId) {
  document.getElementById(btnId)?.addEventListener('click', async () => {
    const text = document.getElementById(srcId)?.textContent ?? '';
    try {
      await navigator.clipboard.writeText(text);
      const btn = document.getElementById(btnId);
      const orig = btn.textContent;
      btn.textContent = '✓'; btn.classList.add('copied');
      setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1800);
    } catch {}
  });
}
setupCopy('copyInstallSh','installSh');
setupCopy('copyInstallPs','installPs');
setupCopy('copyJson','jsonOutput');

/* ── init ── */
renderPresetChips();
renderPalette();
renderActiveList();
updateOutput();
</script>

