---
import Base from '../layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '../i18n/index.ts';
import { getAllPresets } from '../lib/presets.ts';
import { SAMPLE_VALUES } from '../lib/preview.ts';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const presets = await getAllPresets();
const rawBase = import.meta.env.BASE_URL as string;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const SEGMENT_GROUPS = [
  {
    group: lang === 'ko' ? '모델 / 세션' : 'Model / Session',
    segments: [
      { type: 'model',        label: { ko: '모델명', en: 'Model' },           defaultFmt: '◆ {model}',        defaultStyle: 'cyan bold' },
      { type: 'version',      label: { ko: 'CC 버전', en: 'CC Version' },     defaultFmt: 'v{version}',       defaultStyle: 'dim' },
      { type: 'session_id',   label: { ko: '세션 ID', en: 'Session ID' },     defaultFmt: '#{session_id}',    defaultStyle: 'dim' },
      { type: 'session_name', label: { ko: '세션명', en: 'Session Name' },    defaultFmt: '▪ {session_name}', defaultStyle: 'white' },
      { type: 'effort',       label: { ko: '추론 수준', en: 'Effort' },       defaultFmt: '● {effort_level}', defaultStyle: 'magenta' },
    ],
  },
  {
    group: lang === 'ko' ? '작업 공간' : 'Workspace',
    segments: [
      { type: 'cwd',          label: { ko: '현재 디렉터리', en: 'Directory' }, defaultFmt: '{dir_name}',       defaultStyle: 'blue' },
      { type: 'git_branch',   label: { ko: 'Git 브랜치', en: 'Git Branch' }, defaultFmt: '⎇ {branch}',       defaultStyle: 'green' },
      { type: 'git_changes',  label: { ko: '변경 파일', en: 'Changes' },      defaultFmt: '~{changed}',       defaultStyle: 'yellow' },
      { type: 'lines_changed',label: { ko: '코드 변경', en: 'Lines' },        defaultFmt: '+{total_lines_added} -{total_lines_removed}', defaultStyle: 'cyan' },
    ],
  },
  {
    group: lang === 'ko' ? '컨텍스트 창' : 'Context Window',
    segments: [
      { type: 'context_pct',    label: { ko: '컨텍스트 %', en: 'Context %' },    defaultFmt: '{used_percentage}%',   defaultStyle: 'yellow' },
      { type: 'context_bar',    label: { ko: '컨텍스트 바', en: 'Ctx Bar' },     defaultFmt: '[{used_percentage}%]', defaultStyle: 'green' },
      { type: 'tokens_in_out',  label: { ko: '입출력 토큰', en: 'Tokens' },      defaultFmt: '↑{total_input_tokens} ↓{total_output_tokens}', defaultStyle: 'dim' },
      { type: 'cache_tokens',   label: { ko: '캐시', en: 'Cache' },             defaultFmt: '⚡{cache_saved_tokens}', defaultStyle: 'cyan' },
    ],
  },
  {
    group: lang === 'ko' ? '비용 / 시간' : 'Cost / Time',
    segments: [
      { type: 'cost',         label: { ko: '비용', en: 'Cost' },              defaultFmt: '${total_cost_usd:.4f}', defaultStyle: 'yellow' },
      { type: 'duration',     label: { ko: '세션 시간', en: 'Duration' },     defaultFmt: '◷ {duration}',         defaultStyle: 'cyan' },
      { type: 'api_time',     label: { ko: 'API 시간', en: 'API Time' },      defaultFmt: 'api:{total_api_duration_ms}ms', defaultStyle: 'dim' },
    ],
  },
  {
    group: lang === 'ko' ? '한도 / 시스템' : 'Limits / System',
    segments: [
      { type: 'rate_5h',      label: { ko: '5h 한도', en: '5h Rate' },       defaultFmt: '5h:{rate_limit_5h}%',  defaultStyle: 'orange' },
      { type: 'rate_7d',      label: { ko: '7d 한도', en: '7d Rate' },       defaultFmt: '7d:{rate_limit_7d}%',  defaultStyle: 'red' },
      { type: 'vim_mode',     label: { ko: 'Vim 모드', en: 'Vim Mode' },     defaultFmt: '[{vim_mode}]',          defaultStyle: 'blue' },
    ],
  },
  {
    group: lang === 'ko' ? '런타임 / 환경' : 'Runtime / Env',
    segments: [
      { type: 'node_ver',     label: { ko: 'Node 버전', en: 'Node' },        defaultFmt: 'node {node_version}',   defaultStyle: 'green bold' },
      { type: 'python_ver',   label: { ko: 'Python 버전', en: 'Python' },    defaultFmt: 'py{python_version}',    defaultStyle: 'blue bold' },
      { type: 'venv',         label: { ko: '가상환경', en: 'Venv' },         defaultFmt: '({venv_name})',          defaultStyle: 'yellow' },
      { type: 'conda',        label: { ko: 'Conda 환경', en: 'Conda' },      defaultFmt: 'conda:{conda_env}',     defaultStyle: 'yellow' },
      { type: 'docker_ctx',   label: { ko: 'Docker', en: 'Docker' },         defaultFmt: '🐳 {docker_context}',  defaultStyle: 'blue' },
      { type: 'k8s',          label: { ko: 'K8s', en: 'K8s' },              defaultFmt: '☸ {k8s_context}',       defaultStyle: 'cyan' },
      { type: 'aws',          label: { ko: 'AWS 프로파일', en: 'AWS' },      defaultFmt: 'AWS:{aws_profile}',     defaultStyle: 'orange' },
      { type: 'terraform',    label: { ko: 'TF 워크스페이스', en: 'Terraform' }, defaultFmt: 'TF:{tf_workspace}', defaultStyle: 'magenta' },
    ],
  },
];

const COLORS = ['green','cyan','blue','yellow','orange','red','magenta','pink','white','dim','bold'];
const COLOR_HEX: Record<string, string> = {
  green:'#00d97e', cyan:'#22d3ee', blue:'#60a5fa', yellow:'#fbbf24',
  orange:'#fb923c', red:'#f87171', magenta:'#c084fc', pink:'#f472b6',
  white:'#d0d0d0', dim:'#4b5563', bold:'#ffffff',
};

const sampleValuesJson = JSON.stringify(SAMPLE_VALUES);
const segmentGroupsJson = JSON.stringify(SEGMENT_GROUPS);
const colorsJson = JSON.stringify(COLORS);
const colorHexJson = JSON.stringify(COLOR_HEX);
const presetsJson = JSON.stringify(presets.map(p => ({
  id: p.id, title: p.title, category: p.category,
  segments: p.settings.statusline.segments,
  separator: p.settings.statusline.separator ?? '  ',
})));
---

<Base title={lang === 'ko' ? '커스텀 빌더' : 'Custom Builder'}>
<!-- xterm.js CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.min.css" />

<div class="builder-layout">
  <div class="builder-header">
    <h1>{lang === 'ko' ? '커스텀 빌더' : 'Custom Builder'}</h1>
    <p>{lang === 'ko' ? '드래그로 순서 변경 · 색상 선택 · 실제 터미널 미리보기' : 'Drag to reorder · pick colors · real terminal preview'}</p>
  </div>

  <!-- 프리셋 기반 시작 -->
  <div class="preset-start">
    <span class="start-label">{lang === 'ko' ? '프리셋에서 시작:' : 'Start from preset:'}</span>
    <div class="preset-chips" id="presetChips"></div>
  </div>

  <div class="builder-main">
    <!-- 왼쪽: 세그먼트 팔레트 -->
    <div class="panel panel-left">
      <h2 class="panel-title">{lang === 'ko' ? '세그먼트 선택' : 'Segments'}</h2>
      <div id="segmentPalette"></div>
      <div class="separator-row">
        <label class="sep-label">{lang === 'ko' ? '구분자' : 'Separator'}</label>
        <input id="separatorInput" class="sep-input" type="text" value="  " maxlength="10" />
      </div>
    </div>

    <!-- 오른쪽: 활성 세그먼트 (드래그 앤 드롭) -->
    <div class="panel panel-right">
      <h2 class="panel-title">
        {lang === 'ko' ? '활성 세그먼트' : 'Active Segments'}
        <span class="drag-hint">{lang === 'ko' ? '드래그로 순서 변경' : 'drag to reorder'}</span>
      </h2>
      <div class="active-list" id="activeList">
        <div class="empty-hint">{lang === 'ko' ? '왼쪽에서 세그먼트를 추가하세요' : 'Add segments from the left'}</div>
      </div>
    </div>
  </div>

  <!-- xterm.js 실제 터미널 미리보기 -->
  <div class="xterm-section">
    <div class="xterm-header">
      <h2 class="panel-title">{lang === 'ko' ? '실제 터미널 미리보기 (ANSI 색상)' : 'Live Terminal Preview (ANSI colors)'}</h2>
      <span class="xterm-badge">xterm.js</span>
    </div>
    <div class="xterm-wrapper">
      <div id="xterm-container"></div>
    </div>
  </div>

  <!-- 출력 -->
  <div class="output-section">
    <div class="output-tabs">
      <button class="out-tab active" data-tab="install">{lang === 'ko' ? '설치 명령' : 'Install'}</button>
      <button class="out-tab" data-tab="json">JSON</button>
    </div>
    <div class="out-panel" id="panelInstall">
      <div class="install-label">macOS / Linux</div>
      <div class="code-row"><code class="code-block" id="installSh"></code><button class="copy-btn" id="copyInstallSh">{lang === 'ko' ? '복사' : 'Copy'}</button></div>
      <div class="install-label" style="margin-top:0.75rem">Windows (PowerShell)</div>
      <div class="code-row"><code class="code-block" id="installPs"></code><button class="copy-btn" id="copyInstallPs">{lang === 'ko' ? '복사' : 'Copy'}</button></div>
    </div>
    <div class="out-panel hidden" id="panelJson">
      <div class="code-row json-row"><pre class="code-block json-pre" id="jsonOutput"></pre><button class="copy-btn" id="copyJson">{lang === 'ko' ? '복사' : 'Copy'}</button></div>
    </div>
  </div>
</div>
</Base>

<!-- xterm.js 초기화 (is:inline — CDN global 접근) -->
<script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.min.js" is:inline></script>
<script is:inline>
let _xterm = null;
let _xtermReady = false;

const ANSI = {
  reset:'\x1b[0m', bold:'\x1b[1m', dim:'\x1b[2m',
  green:'\x1b[32m', accent:'\x1b[32m', cyan:'\x1b[36m',
  blue:'\x1b[34m', yellow:'\x1b[33m', orange:'\x1b[38;5;173m',
  red:'\x1b[31m', magenta:'\x1b[35m', pink:'\x1b[38;5;213m',
  white:'\x1b[37m', gray:'\x1b[90m',
};

function styleToAnsi(style) {
  if (!style) return '';
  const parts = (style || '').toLowerCase().split(/\s+/);
  return parts.map(p => ANSI[p] || '').join('');
}

function initXterm() {
  const container = document.getElementById('xterm-container');
  if (!container || !window.Terminal) return;
  const term = new window.Terminal({
    theme: {
      background: '#080808',
      foreground: '#555',
      cursor: '#00d97e',
      black: '#1a1a1a', brightBlack: '#333',
      green: '#00d97e', brightGreen: '#00d97e',
      cyan: '#22d3ee', brightCyan: '#22d3ee',
      blue: '#60a5fa', brightBlue: '#60a5fa',
      yellow: '#fbbf24', brightYellow: '#fbbf24',
      red: '#f87171', brightRed: '#f87171',
      magenta: '#c084fc', brightMagenta: '#c084fc',
      white: '#d0d0d0', brightWhite: '#ededed',
    },
    fontFamily: "'Geist Mono','Cascadia Code','Fira Code','SF Mono','Menlo',monospace",
    fontSize: 13,
    lineHeight: 1.4,
    rows: 9,
    cols: 90,
    disableStdin: true,
    cursorBlink: false,
    scrollback: 0,
  });
  term.open(container);
  _xterm = term;
  _xtermReady = true;
  writeXterm(null);
}

function writeXterm(segments, separator) {
  if (!_xterm) return;
  _xterm.reset();
  _xterm.write('\x1b[90m~/GitHub/my-project\x1b[0m \x1b[2m$\x1b[0m claude\r\n');
  _xterm.write('\x1b[2m▶ Analyzing recent changes...\x1b[0m\r\n');
  _xterm.write('\r\n');
  _xterm.write('\x1b[2m  3 files changed, 156 insertions(+), 23 deletions(-)\x1b[0m\r\n');
  _xterm.write('\r\n');
  _xterm.write('\x1b[2m' + '─'.repeat(88) + '\x1b[0m\r\n');

  if (!segments || segments.length === 0) {
    _xterm.write('\x1b[2m(세그먼트를 추가하면 여기 표시됩니다)\x1b[0m');
    return;
  }

  const sep = (separator || '  ');
  const line = segments.map((s, i) => {
    const ansi = styleToAnsi(s.style);
    return (i > 0 ? '\x1b[2m' + (sep.trim() ? sep : ' ') + '\x1b[0m' : '') + ansi + s.text + ANSI.reset;
  }).join('');

  _xterm.write(line);
}

window.addEventListener('xterm:update', (e) => {
  if (_xtermReady) writeXterm(e.detail.segments, e.detail.separator);
});

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', () => setTimeout(initXterm, 100));
} else {
  setTimeout(initXterm, 100);
}
</script>

<!-- 빌더 로직 -->
<script define:vars={{ sampleValuesJson, segmentGroupsJson, colorsJson, colorHexJson, presetsJson, lang }}>
const VALS = JSON.parse(sampleValuesJson);
const GROUPS = JSON.parse(segmentGroupsJson);
const COLORS = JSON.parse(colorsJson);
const COLOR_HEX = JSON.parse(colorHexJson);
const PRESETS = JSON.parse(presetsJson);

let activeSegments = [];
let separator = '  ';
let dragSrcIdx = null;

/* ── render ── */
function renderFmt(fmt) {
  return fmt.replace(/\{([a-zA-Z_.]+)(?::([^}]+))?\}/g, (_, key, spec) => {
    const v = VALS[key];
    if (v === undefined) return `{${key}}`;
    if (spec) { const m = spec.match(/\.(\d+)f/); if (m) return Number(v).toFixed(parseInt(m[1])); }
    return String(v);
  });
}

function styleToCSS(style) {
  if (!style) return 'color:#00d97e';
  const CSS_COLOR = { green:'#00d97e', accent:'#00d97e', cyan:'#22d3ee', blue:'#60a5fa', yellow:'#fbbf24', orange:'#fb923c', red:'#f87171', magenta:'#c084fc', pink:'#f472b6', white:'#d0d0d0', dim:'#4b5563', bold:'#ededed' };
  const parts = style.toLowerCase().split(/\s+/);
  const css = [];
  for (const p of parts) {
    if (p === 'bold') css.push('font-weight:700');
    else if (p === 'dim') css.push('color:#4b5563');
    else if (CSS_COLOR[p]) css.push(`color:${CSS_COLOR[p]}`);
  }
  return css.join(';') || 'color:#00d97e';
}

function getStatusline() {
  return activeSegments.map(s => renderFmt(s.format)).join(separator);
}

/* ── dispatch to xterm ── */
function dispatchXterm() {
  const segs = activeSegments.map(s => ({ text: renderFmt(s.format), style: s.style }));
  window.dispatchEvent(new CustomEvent('xterm:update', { detail: { segments: segs, separator } }));
}

/* ── web preview ── */
function updateWebPreview() {
  // not used — xterm handles preview now
}

/* ── output ── */
function buildJson() {
  return JSON.stringify({ settings: { statusline: { enabled: true, position: 'bottom', separator, segments: activeSegments.map(s => ({ type: s.type, format: s.format, style: s.style })) } } }, null, 2);
}
function updateOutput() {
  const BASE = 'https://raw.githubusercontent.com/NeTrioGit/claude-statusline-market/main';
  const id = 'custom-' + Date.now().toString(36);
  document.getElementById('installSh').textContent = `curl -fsSL ${BASE}/scripts/install-preset.sh | bash -s -- ${id}`;
  document.getElementById('installPs').textContent = `irm ${BASE}/scripts/install-preset.ps1 | iex; Install-Preset ${id}`;
  document.getElementById('jsonOutput').textContent = buildJson();
}

function refresh() { renderActiveList(); renderPalette(); dispatchXterm(); updateOutput(); }

/* ── active list (drag + color picker) ── */
function renderActiveList() {
  const el = document.getElementById('activeList');
  if (!el) return;
  if (activeSegments.length === 0) {
    el.innerHTML = `<div class="empty-hint">${lang === 'ko' ? '왼쪽에서 세그먼트를 추가하세요' : 'Add segments from the left'}</div>`;
    return;
  }
  el.innerHTML = activeSegments.map((s, i) => {
    const swatches = COLORS.map(c => {
      const isActive = s.style?.includes(c);
      return `<span class="swatch ${isActive ? 'swatch-on' : ''}" data-idx="${i}" data-color="${c}" style="background:${COLOR_HEX[c]};" title="${c}"></span>`;
    }).join('');
    return `
    <div class="active-item" draggable="true" data-idx="${i}">
      <div class="active-header">
        <span class="drag-handle" title="drag">⠿</span>
        <span class="active-type">${s.label}</span>
        <span class="active-preview" style="${styleToCSS(s.style)}">${renderFmt(s.format)}</span>
        <div class="active-btns">
          <button class="icon-btn rm" data-action="rm" data-idx="${i}" title="remove">×</button>
        </div>
      </div>
      <div class="swatch-row">${swatches}
        <label class="bold-toggle">
          <input type="checkbox" class="bold-check" data-idx="${i}" ${s.style?.includes('bold') ? 'checked' : ''}> bold
        </label>
      </div>
      <div class="fmt-row">
        <input class="fmt-input" data-idx="${i}" value="${s.format.replace(/"/g, '&quot;')}" />
      </div>
    </div>`;
  }).join('');

  /* swatches */
  el.querySelectorAll('.swatch').forEach(sw => {
    sw.addEventListener('click', () => {
      const idx = parseInt(sw.dataset.idx);
      const color = sw.dataset.color;
      const cur = activeSegments[idx].style || '';
      const parts = cur.split(/\s+/).filter(p => !COLOR_HEX[p] && p !== 'dim');
      parts.push(color);
      activeSegments[idx].style = parts.join(' ').trim();
      refresh();
    });
  });

  /* bold toggle */
  el.querySelectorAll('.bold-check').forEach(cb => {
    cb.addEventListener('change', () => {
      const idx = parseInt(cb.dataset.idx);
      const parts = (activeSegments[idx].style || '').split(/\s+/).filter(p => p !== 'bold');
      if (cb.checked) parts.push('bold');
      activeSegments[idx].style = parts.join(' ').trim();
      refresh();
    });
  });

  /* format input */
  el.querySelectorAll('.fmt-input').forEach(inp => {
    inp.addEventListener('input', e => {
      const idx = parseInt(e.target.dataset.idx);
      activeSegments[idx].format = e.target.value;
      refresh();
    });
  });

  /* remove */
  el.querySelectorAll('.icon-btn.rm').forEach(btn => {
    btn.addEventListener('click', () => {
      activeSegments.splice(parseInt(btn.dataset.idx), 1);
      refresh();
    });
  });

  /* drag and drop */
  el.querySelectorAll('.active-item').forEach(item => {
    item.addEventListener('dragstart', e => {
      dragSrcIdx = parseInt(item.dataset.idx);
      item.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    item.addEventListener('dragend', () => {
      item.classList.remove('dragging');
      el.querySelectorAll('.active-item').forEach(i => i.classList.remove('drag-over'));
    });
    item.addEventListener('dragover', e => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      el.querySelectorAll('.active-item').forEach(i => i.classList.remove('drag-over'));
      if (parseInt(item.dataset.idx) !== dragSrcIdx) item.classList.add('drag-over');
    });
    item.addEventListener('drop', e => {
      e.preventDefault();
      const targetIdx = parseInt(item.dataset.idx);
      if (dragSrcIdx !== null && dragSrcIdx !== targetIdx) {
        const [moved] = activeSegments.splice(dragSrcIdx, 1);
        activeSegments.splice(targetIdx, 0, moved);
        refresh();
      }
    });
  });
}

/* ── palette ── */
function renderPalette() {
  const el = document.getElementById('segmentPalette');
  if (!el) return;
  el.innerHTML = GROUPS.map(g => `
    <div class="seg-group">
      <div class="seg-group-label">${g.group}</div>
      <div class="seg-group-items">
        ${g.segments.map(seg => {
          const active = activeSegments.some(s => s.type === seg.type);
          return `<button class="seg-btn ${active ? 'seg-active' : ''}" data-type="${seg.type}">
            <span class="seg-lbl">${seg.label[lang] ?? seg.label.ko}</span>
            <span class="seg-sample" style="${active ? `color:${COLOR_HEX[seg.defaultStyle?.split(' ')[0]] || '#00d97e'}` : ''}">${renderFmt(seg.defaultFmt)}</span>
            <span class="seg-toggle">${active ? '✓' : '+'}</span>
          </button>`;
        }).join('')}
      </div>
    </div>`).join('');

  el.querySelectorAll('.seg-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.type;
      const idx = activeSegments.findIndex(s => s.type === type);
      if (idx !== -1) { activeSegments.splice(idx, 1); }
      else {
        let def = null;
        for (const g of GROUPS) { def = g.segments.find(s => s.type === type); if (def) break; }
        if (!def) return;
        activeSegments.push({ type, format: def.defaultFmt, style: def.defaultStyle, label: def.label[lang] ?? def.label.ko });
      }
      refresh();
    });
  });
}

/* ── preset chips ── */
function renderPresetChips() {
  const el = document.getElementById('presetChips');
  if (!el) return;
  el.innerHTML = PRESETS.map(p => `<button class="preset-chip" data-id="${p.id}">${p.title[lang] ?? p.title.ko}</button>`).join('');
  el.querySelectorAll('.preset-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = PRESETS.find(x => x.id === btn.dataset.id);
      if (!p) return;
      separator = p.separator ?? '  ';
      document.getElementById('separatorInput').value = separator;
      activeSegments = p.segments.map(s => {
        let def = null;
        for (const g of GROUPS) { def = g.segments.find(d => d.type === s.type); if (def) break; }
        return { type: s.type, format: s.format ?? def?.defaultFmt ?? s.type, style: s.style ?? def?.defaultStyle ?? 'green', label: def?.label?.[lang] ?? def?.label?.ko ?? s.type };
      });
      el.querySelectorAll('.preset-chip').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      refresh();
    });
  });
}

/* ── separator ── */
document.getElementById('separatorInput')?.addEventListener('input', e => { separator = e.target.value; refresh(); });

/* ── output tabs ── */
document.querySelectorAll('.out-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.out-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const which = tab.dataset.tab;
    document.getElementById('panelInstall').classList.toggle('hidden', which !== 'install');
    document.getElementById('panelJson').classList.toggle('hidden', which !== 'json');
  });
});

/* ── copy ── */
['copyInstallSh:installSh','copyInstallPs:installPs','copyJson:jsonOutput'].forEach(pair => {
  const [btnId, srcId] = pair.split(':');
  document.getElementById(btnId)?.addEventListener('click', async () => {
    const text = document.getElementById(srcId)?.textContent ?? '';
    try {
      await navigator.clipboard.writeText(text);
      const btn = document.getElementById(btnId);
      const orig = btn.textContent; btn.textContent = '✓'; btn.classList.add('copied');
      setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1800);
    } catch {}
  });
});

/* ── init ── */
renderPresetChips(); renderPalette(); renderActiveList(); updateOutput();
</script>

