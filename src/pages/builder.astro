---
import Base from '../layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '../i18n/index.ts';
import { getAllPresets } from '../lib/presets.ts';
import { SAMPLE_VALUES } from '../lib/preview.ts';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const presets = await getAllPresets();
const rawBase = import.meta.env.BASE_URL as string;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const SEGMENT_TYPES = [
  { type: 'model',        label: { ko: '모델명', en: 'Model' },         defaultFormat: '{model}',                    sample: SAMPLE_VALUES.model },
  { type: 'cwd',          label: { ko: '디렉터리', en: 'Directory' },    defaultFormat: '{cwd}',                      sample: SAMPLE_VALUES.cwd },
  { type: 'cost',         label: { ko: '비용', en: 'Cost' },             defaultFormat: '${total_cost:.4f}',          sample: `$${(SAMPLE_VALUES.total_cost as number).toFixed(4)}` },
  { type: 'tokens',       label: { ko: '토큰', en: 'Tokens' },           defaultFormat: '{input_tokens}+{output_tokens}', sample: `${SAMPLE_VALUES.input_tokens}+${SAMPLE_VALUES.output_tokens}` },
  { type: 'cache',        label: { ko: '캐시', en: 'Cache' },            defaultFormat: 'C:{cache_hit_rate:.0f}%',    sample: `C:${Math.round(SAMPLE_VALUES.cache_hit_rate as number)}%` },
  { type: 'git',          label: { ko: 'Git 브랜치', en: 'Git Branch' }, defaultFormat: ' {branch}',                sample: ` ${SAMPLE_VALUES.branch}` },
  { type: 'git_changes',  label: { ko: '변경 파일', en: 'Changes' },     defaultFormat: '{changed} changed',          sample: `${SAMPLE_VALUES.changed} changed` },
  { type: 'session_time', label: { ko: '세션 시간', en: 'Session Time' }, defaultFormat: '{duration}',               sample: SAMPLE_VALUES.duration },
];

const sampleValuesJson = JSON.stringify(SAMPLE_VALUES);
const segmentTypesJson = JSON.stringify(SEGMENT_TYPES);
const presetsJson = JSON.stringify(presets.map(p => ({
  id: p.id,
  title: p.title,
  category: p.category,
  segments: p.settings.statusline.segments,
  separator: p.settings.statusline.separator ?? '  ',
})));
---
<Base title={lang === 'ko' ? '커스텀 빌더' : 'Custom Builder'}>
  <div class="builder-layout">
    <div class="builder-header">
      <h1>{lang === 'ko' ? '커스텀 빌더' : 'Custom Builder'}</h1>
      <p>{lang === 'ko' ? '세그먼트를 추가하고 순서를 바꿔 나만의 상태바를 만드세요.' : 'Add and reorder segments to build your own statusbar.'}</p>
    </div>

    <!-- Option B: 프리셋 기반 시작 -->
    <div class="preset-start">
      <span class="start-label">{lang === 'ko' ? '프리셋 기반으로 시작:' : 'Start from a preset:'}</span>
      <div class="preset-chips" id="presetChips"></div>
    </div>

    <div class="builder-main">
      <!-- 왼쪽: 세그먼트 선택 -->
      <div class="panel panel-left">
        <h2 class="panel-title">{lang === 'ko' ? '세그먼트' : 'Segments'}</h2>
        <div class="segment-list" id="availableSegments"></div>
        <div class="separator-row">
          <label class="sep-label">{lang === 'ko' ? '구분자' : 'Separator'}</label>
          <input id="separatorInput" class="sep-input" type="text" value="  " maxlength="10" />
        </div>
      </div>

      <!-- 오른쪽: 활성 세그먼트 + 미리보기 -->
      <div class="panel panel-right">
        <h2 class="panel-title">{lang === 'ko' ? '활성 세그먼트' : 'Active Segments'}</h2>
        <div class="active-list" id="activeList">
          <div class="empty-hint">{lang === 'ko' ? '왼쪽에서 세그먼트를 추가하세요' : 'Add segments from the left'}</div>
        </div>
      </div>
    </div>

    <!-- 터미널 미리보기 -->
    <div class="preview-section">
      <h2 class="panel-title">{lang === 'ko' ? '미리보기' : 'Preview'}</h2>
      <div class="preview-terminal">
        <div class="term-chrome">
          <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
          <span class="term-path">~/GitHub/my-project</span>
        </div>
        <div class="term-body">
          <div class="term-line"><span class="term-acc">~/GitHub/my-project</span> <span class="term-dim">$</span> claude</div>
          <div class="term-line term-dim">▶ Analyzing changes...</div>
          <div class="term-line">&nbsp;</div>
          <div class="term-line term-dim">  3 files changed, 47 insertions(+)</div>
        </div>
        <div class="term-status" id="livePreview">
          <span class="status-placeholder">{lang === 'ko' ? '세그먼트를 추가하면 여기 표시됩니다' : 'Add segments to see preview'}</span>
        </div>
      </div>
    </div>

    <!-- 출력 -->
    <div class="output-section">
      <div class="output-tabs">
        <button class="out-tab active" data-tab="install">{lang === 'ko' ? '설치 명령' : 'Install'}</button>
        <button class="out-tab" data-tab="json">JSON</button>
      </div>
      <div class="out-panel" id="panelInstall">
        <div class="install-label">macOS / Linux</div>
        <div class="code-row">
          <code class="code-block" id="installSh"></code>
          <button class="copy-btn" id="copyInstallSh">{lang === 'ko' ? '복사' : 'Copy'}</button>
        </div>
        <div class="install-label" style="margin-top:0.75rem">Windows (PowerShell)</div>
        <div class="code-row">
          <code class="code-block" id="installPs"></code>
          <button class="copy-btn" id="copyInstallPs">{lang === 'ko' ? '복사' : 'Copy'}</button>
        </div>
      </div>
      <div class="out-panel hidden" id="panelJson">
        <div class="code-row json-row">
          <pre class="code-block json-pre" id="jsonOutput"></pre>
          <button class="copy-btn" id="copyJson">{lang === 'ko' ? '복사' : 'Copy'}</button>
        </div>
      </div>
    </div>
  </div>
</Base>

<script define:vars={{ sampleValuesJson, segmentTypesJson, presetsJson, lang }}>
const VALS = JSON.parse(sampleValuesJson);
const SEG_TYPES = JSON.parse(segmentTypesJson);
const PRESETS = JSON.parse(presetsJson);

let activeSegments = [];
let separator = '  ';

// ── render format string with sample values ──
function renderFmt(fmt) {
  return fmt.replace(/\{([a-zA-Z_.]+)(?::([^}]+))?\}/g, (_, key, spec) => {
    const v = VALS[key];
    if (v === undefined) return `{${key}}`;
    if (spec) {
      const m = spec.match(/\.(\d+)f/);
      if (m) return Number(v).toFixed(parseInt(m[1]));
    }
    return String(v);
  });
}

function getStatusline() {
  return activeSegments.map(s => renderFmt(s.format)).join(separator);
}

function tokenBar(pct, w = 12) {
  const f = Math.round((pct / 100) * w);
  return '█'.repeat(f) + '░'.repeat(w - f);
}

// ── live preview ──
function updatePreview() {
  const el = document.getElementById('livePreview');
  if (!el) return;
  if (activeSegments.length === 0) {
    el.innerHTML = `<span class="status-placeholder">${lang === 'ko' ? '세그먼트를 추가하면 여기 표시됩니다' : 'Add segments to see preview'}</span>`;
    return;
  }
  const sl = getStatusline();
  const hasCache = activeSegments.some(s => s.type === 'cache');
  const bar = hasCache ? tokenBar(VALS.cache_hit_rate) : '';
  el.innerHTML = `<span class="sline">${sl}</span>${bar ? `<span class="sline-bar">${bar} ${Math.round(VALS.cache_hit_rate)}%</span>` : ''}`;
}

// ── output ──
function buildSettingsJson() {
  const obj = {
    statusline: {
      enabled: true,
      position: 'bottom',
      separator,
      segments: activeSegments.map(s => ({ type: s.type, format: s.format })),
    },
  };
  return JSON.stringify({ settings: obj }, null, 2);
}

function updateOutput() {
  const BASE_URL = 'https://raw.githubusercontent.com/NeTrioGit/claude-statusline-market/main';
  const customId = 'custom-' + Date.now().toString(36);
  document.getElementById('installSh').textContent =
    `curl -fsSL ${BASE_URL}/scripts/install-preset.sh | bash -s -- ${customId}`;
  document.getElementById('installPs').textContent =
    `irm ${BASE_URL}/scripts/install-preset.ps1 | iex; Install-Preset ${customId}`;
  document.getElementById('jsonOutput').textContent = buildSettingsJson();
}

// ── active list render ──
function renderActiveList() {
  const el = document.getElementById('activeList');
  if (activeSegments.length === 0) {
    el.innerHTML = `<div class="empty-hint">${lang === 'ko' ? '왼쪽에서 세그먼트를 추가하세요' : 'Add segments from the left'}</div>`;
    return;
  }
  el.innerHTML = activeSegments.map((s, i) => `
    <div class="active-item" data-idx="${i}">
      <div class="active-info">
        <span class="active-type">${s.label}</span>
        <input class="fmt-input" data-idx="${i}" value="${s.format.replace(/"/g, '&quot;')}" />
      </div>
      <div class="active-btns">
        <button class="icon-btn" data-action="up" data-idx="${i}" ${i === 0 ? 'disabled' : ''}>↑</button>
        <button class="icon-btn" data-action="down" data-idx="${i}" ${i === activeSegments.length - 1 ? 'disabled' : ''}>↓</button>
        <button class="icon-btn rm" data-action="rm" data-idx="${i}">×</button>
      </div>
    </div>
  `).join('');

  el.querySelectorAll('.fmt-input').forEach(inp => {
    inp.addEventListener('input', e => {
      const idx = parseInt(e.target.dataset.idx);
      activeSegments[idx].format = e.target.value;
      updatePreview();
      updateOutput();
    });
  });
  el.querySelectorAll('.icon-btn').forEach(btn => {
    btn.addEventListener('click', e => {
      const idx = parseInt(btn.dataset.idx);
      const action = btn.dataset.action;
      if (action === 'up' && idx > 0) {
        [activeSegments[idx - 1], activeSegments[idx]] = [activeSegments[idx], activeSegments[idx - 1]];
      } else if (action === 'down' && idx < activeSegments.length - 1) {
        [activeSegments[idx], activeSegments[idx + 1]] = [activeSegments[idx + 1], activeSegments[idx]];
      } else if (action === 'rm') {
        activeSegments.splice(idx, 1);
      }
      renderActiveList();
      renderAvailable();
      updatePreview();
      updateOutput();
    });
  });
}

// ── available segments ──
function renderAvailable() {
  const el = document.getElementById('availableSegments');
  el.innerHTML = SEG_TYPES.map(seg => {
    const active = activeSegments.some(s => s.type === seg.type);
    return `
      <button class="seg-btn ${active ? 'seg-active' : ''}" data-type="${seg.type}">
        <span class="seg-btn-label">${seg.label[lang] ?? seg.label.ko}</span>
        <span class="seg-btn-sample">${renderFmt(seg.defaultFormat)}</span>
        ${active ? '<span class="seg-btn-check">✓</span>' : '<span class="seg-btn-add">+</span>'}
      </button>
    `;
  }).join('');

  el.querySelectorAll('.seg-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.type;
      const already = activeSegments.findIndex(s => s.type === type);
      if (already !== -1) {
        activeSegments.splice(already, 1);
      } else {
        const def = SEG_TYPES.find(s => s.type === type);
        activeSegments.push({ type, format: def.defaultFormat, label: def.label[lang] ?? def.label.ko });
      }
      renderActiveList();
      renderAvailable();
      updatePreview();
      updateOutput();
    });
  });
}

// ── preset chips ──
function renderPresetChips() {
  const el = document.getElementById('presetChips');
  el.innerHTML = PRESETS.map(p => `
    <button class="preset-chip" data-id="${p.id}">
      ${p.title[lang] ?? p.title.ko}
    </button>
  `).join('');
  el.querySelectorAll('.preset-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = PRESETS.find(x => x.id === btn.dataset.id);
      if (!p) return;
      separator = p.separator ?? '  ';
      document.getElementById('separatorInput').value = separator;
      activeSegments = p.segments.map(s => {
        const def = SEG_TYPES.find(d => d.type === s.type);
        return {
          type: s.type,
          format: s.format ?? def?.defaultFormat ?? s.type,
          label: def?.label?.[lang] ?? def?.label?.ko ?? s.type,
        };
      });
      renderActiveList();
      renderAvailable();
      updatePreview();
      updateOutput();
      el.querySelectorAll('.preset-chip').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
    });
  });
}

// ── separator ──
document.getElementById('separatorInput')?.addEventListener('input', e => {
  separator = e.target.value;
  updatePreview();
  updateOutput();
});

// ── output tabs ──
document.querySelectorAll('.out-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.out-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const which = tab.dataset.tab;
    document.getElementById('panelInstall').classList.toggle('hidden', which !== 'install');
    document.getElementById('panelJson').classList.toggle('hidden', which !== 'json');
  });
});

// ── copy buttons ──
function setupCopy(btnId, sourceId) {
  document.getElementById(btnId)?.addEventListener('click', async () => {
    const text = document.getElementById(sourceId)?.textContent ?? '';
    try {
      await navigator.clipboard.writeText(text);
      const btn = document.getElementById(btnId);
      const orig = btn.textContent;
      btn.textContent = '✓';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1800);
    } catch {}
  });
}
setupCopy('copyInstallSh', 'installSh');
setupCopy('copyInstallPs', 'installPs');
setupCopy('copyJson', 'jsonOutput');

// ── init ──
renderPresetChips();
renderAvailable();
renderActiveList();
updateOutput();
</script>

<style>
.builder-layout { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem 5rem; }
.builder-header { margin-bottom: 2rem; }
.builder-header h1 { font-size: 1.75rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 0.375rem; }
.builder-header p { color: var(--text-dim); font-size: 0.9375rem; }

.preset-start { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2rem; padding: 1rem 1.25rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); }
.start-label { font-size: 0.8125rem; color: var(--text-muted); white-space: nowrap; }
.preset-chips { display: flex; flex-wrap: wrap; gap: 0.375rem; }
.preset-chip { padding: 0.25rem 0.75rem; border-radius: 999px; border: 1px solid var(--border); background: transparent; color: var(--text-dim); font-size: 0.8125rem; font-family: inherit; cursor: pointer; transition: all 0.15s; }
.preset-chip:hover { border-color: var(--border-hover); color: var(--text); }
.preset-chip.active { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

.builder-main { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
@media (max-width: 700px) { .builder-main { grid-template-columns: 1fr; } }

.panel { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem; }
.panel-title { font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.875rem; }

.segment-list { display: flex; flex-direction: column; gap: 0.375rem; margin-bottom: 1rem; }
.seg-btn {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.5rem 0.75rem; border-radius: var(--radius);
  border: 1px solid var(--border); background: transparent;
  color: var(--text-dim); font-family: inherit; cursor: pointer;
  text-align: left; transition: all 0.15s;
}
.seg-btn:hover { border-color: var(--border-hover); color: var(--text); background: var(--bg-hover); }
.seg-btn.seg-active { border-color: var(--accent); background: var(--accent-dim); color: var(--accent); }
.seg-btn-label { font-size: 0.8125rem; font-weight: 500; flex: 0 0 auto; min-width: 80px; }
.seg-btn-sample { font-size: 0.75rem; font-family: var(--font-mono); color: #555; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.seg-btn.seg-active .seg-btn-sample { color: #2a7a50; }
.seg-btn-add, .seg-btn-check { font-size: 0.875rem; flex-shrink: 0; margin-left: auto; }
.seg-btn-check { color: var(--accent); }
.seg-btn-add { color: var(--text-muted); }

.separator-row { display: flex; align-items: center; gap: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--border); }
.sep-label { font-size: 0.8125rem; color: var(--text-muted); }
.sep-input { background: var(--bg); border: 1px solid var(--border); border-radius: 4px; color: var(--text); font-family: var(--font-mono); font-size: 0.8125rem; padding: 0.25rem 0.5rem; width: 80px; outline: none; }
.sep-input:focus { border-color: var(--accent); }

.active-list { display: flex; flex-direction: column; gap: 0.375rem; min-height: 120px; }
.empty-hint { font-size: 0.8125rem; color: var(--text-muted); padding: 1rem 0; text-align: center; }
.active-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.625rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg); }
.active-info { flex: 1; display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; }
.active-type { font-size: 0.75rem; font-weight: 500; color: var(--text-muted); }
.fmt-input { background: transparent; border: none; border-bottom: 1px solid var(--border); color: var(--text-dim); font-family: var(--font-mono); font-size: 0.75rem; outline: none; width: 100%; padding: 0.1rem 0; }
.fmt-input:focus { border-bottom-color: var(--accent); color: var(--text); }
.active-btns { display: flex; gap: 0.25rem; flex-shrink: 0; }
.icon-btn { width: 24px; height: 24px; border-radius: 4px; border: 1px solid var(--border); background: transparent; color: var(--text-muted); font-size: 0.75rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
.icon-btn:hover:not(:disabled) { border-color: var(--border-hover); color: var(--text); }
.icon-btn:disabled { opacity: 0.3; cursor: default; }
.icon-btn.rm { color: #666; }
.icon-btn.rm:hover { color: #ff5f57; border-color: #ff5f57; }

.preview-section { margin-bottom: 1.5rem; }
.preview-terminal { background: #0d0d0d; border: 1px solid #1e1e1e; border-radius: 10px; overflow: hidden; font-family: var(--font-mono); font-size: 0.8125rem; }
.term-chrome { display: flex; align-items: center; gap: 5px; padding: 9px 13px; border-bottom: 1px solid #1a1a1a; }
.dot { width: 10px; height: 10px; border-radius: 50%; }
.dot.r { background: #ff5f57; } .dot.y { background: #febc2e; } .dot.g { background: #28c840; }
.term-path { margin-left: 8px; font-size: 0.75rem; color: #444; }
.term-body { padding: 0.875rem 1.25rem; }
.term-line { color: #666; line-height: 1.75; }
.term-dim { color: #3a3a3a; }
.term-acc { color: var(--accent); }
.term-status { padding: 5px 13px; background: #111; border-top: 1px solid #1a1a1a; display: flex; align-items: center; justify-content: space-between; gap: 1rem; min-height: 28px; }
.sline { font-size: 0.75rem; color: var(--accent); flex: 1; }
.sline-bar { font-size: 0.7rem; color: #555; white-space: nowrap; }
.status-placeholder { font-size: 0.75rem; color: #333; }

.output-section { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
.output-tabs { display: flex; border-bottom: 1px solid var(--border); }
.out-tab { padding: 0.625rem 1.25rem; background: transparent; border: none; color: var(--text-muted); font-size: 0.875rem; font-family: inherit; cursor: pointer; transition: all 0.15s; border-bottom: 2px solid transparent; }
.out-tab:hover { color: var(--text); }
.out-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.out-panel { padding: 1.25rem; }
.out-panel.hidden { display: none; }
.install-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); margin-bottom: 0.375rem; }
.code-row { display: flex; gap: 0.5rem; align-items: center; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 0.625rem 0.875rem; }
.code-block { flex: 1; font-size: 0.8125rem; color: var(--text-dim); white-space: nowrap; overflow: auto; font-family: var(--font-mono); }
.json-row { align-items: flex-start; }
.json-pre { white-space: pre; flex: 1; font-size: 0.8125rem; color: var(--text-dim); font-family: var(--font-mono); overflow: auto; margin: 0; max-height: 240px; }
.copy-btn { flex-shrink: 0; padding: 0.25rem 0.625rem; background: transparent; border: 1px solid var(--border); border-radius: 4px; color: var(--text-dim); font-size: 0.75rem; cursor: pointer; font-family: inherit; transition: all 0.15s; }
.copy-btn:hover { border-color: var(--border-hover); color: var(--text); }
.copy-btn.copied { color: var(--accent); border-color: var(--accent); }
</style>
