---
import Base from '../layouts/Base.astro';
import PresetCard from '../components/PresetCard.astro';
import { getLangFromUrl, useTranslations } from '../i18n/index.ts';
import { getAllPresets } from '../lib/presets.ts';
import { getBase } from '../lib/utils.ts';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const presets = await getAllPresets();

const base = getBase();

const categories = ['minimal', 'productivity', 'cost', 'git', 'powerline', 'custom'];
---
<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">{t('hero.badge')}</div>
      <h1 class="hero-title" set:html={t('hero.title').replace('\n', '<br />')} />
      <p class="hero-subtitle">{t('hero.subtitle')}</p>
      <div class="hero-actions">
        <a href="https://github.com/NeTrioGit/claude-statusline-market/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener" class="btn btn-primary">
          {lang === 'ko' ? '프리셋 기여하기' : 'Contribute a Preset'}
        </a>
        <a href="https://github.com/NeTrioGit/claude-statusline-market" target="_blank" rel="noopener" class="btn btn-ghost">
          {t('hero.cta_github')}
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="gallery-section">
    <div class="gallery-inner">
      <div class="gallery-controls">
        <div class="controls-top">
          <input
            type="search"
            id="search"
            class="search-input"
            placeholder={t('gallery.search_placeholder')}
            autocomplete="off"
          />
          <div class="view-toggle" aria-label="view mode">
            <button class="view-btn active" data-view="grid" title={lang === 'ko' ? '그리드 보기' : 'Grid view'}>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="1" y="1" width="5" height="5" rx="1"/><rect x="8" y="1" width="5" height="5" rx="1"/>
                <rect x="1" y="8" width="5" height="5" rx="1"/><rect x="8" y="8" width="5" height="5" rx="1"/>
              </svg>
            </button>
            <button class="view-btn" data-view="list" title={lang === 'ko' ? '목록 보기' : 'List view'}>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="1" y1="3" x2="13" y2="3"/><line x1="1" y1="7" x2="13" y2="7"/><line x1="1" y1="11" x2="13" y2="11"/>
              </svg>
            </button>
          </div>
        </div>
        <div class="category-pills">
          <button class="pill active" data-category="all">{t('gallery.all_categories')}</button>
          {categories.map(cat => (
            <button class="pill" data-category={cat}>{t(`categories.${cat}`)}</button>
          ))}
        </div>
      </div>

      <div class="gallery-count" id="count">
        {t('gallery.count').replace('{count}', String(presets.length))}
      </div>

      <div class="grid" id="grid">
        {presets.map(preset => (
          <PresetCard
            id={preset.id}
            title={preset.title}
            description={preset.description}
            category={preset.category}
            tags={preset.tags ?? []}
            tool={preset.tool}
            lang={lang}
            base={base}
            widgets={preset.ccstatusline_settings.lines[0] ?? []}
          />
        ))}
      </div>

      <div class="empty" id="empty" style="display:none">
        <p id="empty-main">{t('gallery.no_results')}</p>
        <p class="empty-hint" id="empty-hint">{t('gallery.no_results_hint')}</p>
        <p id="empty-cat-msg" style="display:none"></p>
      </div>

      <!-- Contribute CTA -->
      <div class="contribute-cta">
        <p class="contribute-text">
          {lang === 'ko' ? '당신만의 프리셋을 공유하고 커뮤니티에 기여해보세요.' : 'Share your preset and help the community grow.'}
        </p>
        <a
          href="https://github.com/NeTrioGit/claude-statusline-market/blob/main/CONTRIBUTING.md"
          target="_blank"
          rel="noopener"
          class="btn btn-ghost"
        >
          {lang === 'ko' ? '프리셋 공유하기' : 'Share a Preset'}
        </a>
      </div>
    </div>
  </section>
</Base>

<script>
const searchEl = document.getElementById('search') as HTMLInputElement;
const pills = document.querySelectorAll<HTMLElement>('.pill');
const cards = document.querySelectorAll<HTMLElement>('.card');
const countEl = document.getElementById('count')!;
const emptyEl = document.getElementById('empty')!;
const emptyMain = document.getElementById('empty-main')!;
const emptyHint = document.getElementById('empty-hint')!;
const emptyCatMsg = document.getElementById('empty-cat-msg')!;

let activeCategory = 'all';
let query = '';

function filterCards() {
  let visible = 0;
  cards.forEach(card => {
    const a = card as HTMLAnchorElement;
    const href = a.href;
    const id = href.split('/').pop() ?? '';
    const title = card.querySelector('.card-title')?.textContent?.toLowerCase() ?? '';
    const desc = card.querySelector('.card-desc')?.textContent?.toLowerCase() ?? '';
    const tags = Array.from(card.querySelectorAll('.tag')).map(t => t.textContent?.toLowerCase() ?? '').join(' ');
    const cardCategory = (card as HTMLElement).dataset.category ?? '';

    const matchesQuery = !query || title.includes(query) || desc.includes(query) || tags.includes(query) || id.includes(query);
    const matchesCat = activeCategory === 'all' || cardCategory === activeCategory;

    const show = matchesQuery && matchesCat;
    (card as HTMLElement).style.display = show ? '' : 'none';
    if (show) visible++;
  });

  const countText = countEl.getAttribute('data-template') ?? '';
  countEl.textContent = countText.replace('{count}', String(visible));
  emptyEl.style.display = visible === 0 ? '' : 'none';

  if (visible === 0 && activeCategory !== 'all') {
    const label = document.querySelector<HTMLElement>('.pill.active')?.textContent?.trim() ?? activeCategory;
    emptyCatMsg.textContent = `'${label}' 카테고리의 프리셋이 없습니다.`;
    emptyMain.style.display = 'none';
    emptyHint.style.display = 'none';
    emptyCatMsg.style.display = '';
  } else {
    emptyMain.style.display = '';
    emptyHint.style.display = '';
    emptyCatMsg.style.display = 'none';
  }
}

// store template
const rawCount = countEl.textContent ?? '';
countEl.setAttribute('data-template', rawCount.replace(/\d+/, '{count}'));

searchEl?.addEventListener('input', e => {
  query = (e.target as HTMLInputElement).value.toLowerCase().trim();
  filterCards();
});

pills.forEach(pill => {
  pill.addEventListener('click', () => {
    pills.forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    activeCategory = pill.dataset.category ?? 'all';
    filterCards();
  });
});

// View toggle
const grid = document.getElementById('grid')!;
const viewBtns = document.querySelectorAll<HTMLElement>('.view-btn');
viewBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    viewBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const view = btn.dataset.view;
    grid.classList.toggle('list-view', view === 'list');
  });
});
</script>

<style>
.hero {
  padding: 6rem 1.5rem 4rem;
  text-align: center;
}
.hero-inner {
  max-width: 640px;
  margin: 0 auto;
}
.hero-badge {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-dim);
  padding: 0.25rem 0.75rem;
  border-radius: 999px;
  margin-bottom: 1.5rem;
}
.hero-title {
  font-size: clamp(2rem, 5vw, 3.25rem);
  font-weight: 700;
  letter-spacing: -0.04em;
  line-height: 1.1;
  margin-bottom: 1rem;
  color: var(--text);
}
.hero-subtitle {
  font-size: 1rem;
  color: var(--text-dim);
  line-height: 1.7;
  margin-bottom: 2rem;
}
.hero-actions {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
}
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.625rem 1.25rem;
  border-radius: var(--radius);
  font-size: 0.875rem;
  font-weight: 500;
  transition: all 0.15s;
  cursor: pointer;
  border: 1px solid transparent;
}
.btn-primary {
  background: var(--accent);
  color: #000;
  border-color: var(--accent);
}
.btn-primary:hover { opacity: 0.88; }
.btn-ghost {
  border-color: var(--border);
  color: var(--text-dim);
}
.btn-ghost:hover { border-color: var(--border-hover); color: var(--text); background: var(--bg-hover); }
.gallery-section { padding: 0 1.5rem 4rem; }
.gallery-inner { max-width: 960px; margin: 0 auto; }
.gallery-controls {
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
  margin-bottom: 2rem;
}
.controls-top {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.search-input {
  flex: 1;
  padding: 0.5rem 0.875rem;
  background: #111;
  border: 1px solid #1e1e1e;
  border-radius: var(--radius);
  color: var(--text);
  font-size: 0.875rem;
  font-family: inherit;
  outline: none;
  transition: border-color 0.15s;
}
.search-input:focus { border-color: #2e2e2e; }
.search-input::placeholder { color: #333; }
.category-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
}
.pill {
  padding: 0.25rem 0.75rem;
  border-radius: 999px;
  border: 1px solid #1e1e1e;
  background: transparent;
  color: #555;
  font-size: 0.8125rem;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.15s;
}
.pill:hover { border-color: #2e2e2e; color: var(--text-dim); }
.pill.active { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
.view-toggle {
  display: flex;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  flex-shrink: 0;
}
.view-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.4rem 0.625rem;
  background: transparent;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  transition: color 0.15s, background 0.15s;
}
.view-btn:hover { color: var(--text-dim); background: var(--bg-hover); }
.view-btn.active { color: var(--accent); background: var(--accent-dim); }
.gallery-count {
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
  letter-spacing: 0.02em;
}
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}
.grid.list-view {
  grid-template-columns: 1fr;
  gap: 0.5rem;
}
.grid.list-view :global(.card) {
  flex-direction: row;
  height: 80px;
  overflow: hidden;
}
/* 정보 영역: 왼쪽 고정폭 */
.grid.list-view :global(.card-info) {
  order: 0;
  width: 220px;
  flex-shrink: 0;
  padding: 0.625rem 0.875rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
/* 구분선 */
.grid.list-view :global(.card-divider) {
  order: 1;
  width: 1px;
  height: auto;
  background: linear-gradient(180deg, #161616 0%, #1e1e1e 50%, #161616 100%);
}
/* 프리뷰 영역: 오른쪽, 나머지 전체 */
.grid.list-view :global(.card-terminal) {
  order: 2;
  flex: 1;
  min-width: 0;
}
.grid.list-view :global(.card-tags) { display: none; }
.grid.list-view :global(.card-desc) { display: none; }
.grid.list-view :global(.term-footer) { display: none; }
.empty { text-align: center; padding: 4rem 1rem; }
.empty p { color: var(--text-dim); margin-bottom: 0.5rem; }
.empty-hint { font-size: 0.875rem; color: var(--text-muted); }
.contribute-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-top: 3rem;
  padding: 1.25rem 1.5rem;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-card);
  flex-wrap: wrap;
}
.contribute-text {
  font-size: 0.9375rem;
  color: var(--text-dim);
  margin: 0;
  flex: 1;
  min-width: 200px;
}
</style>
