---
import Base from '../../layouts/Base.astro';
import PresetCard from '../../components/PresetCard.astro';
import { useTranslations } from '../../i18n/index.ts';
import { getAllPresets } from '../../lib/presets.ts';
import { getBase } from '../../lib/utils.ts';

const lang = 'en' as const;
const t = useTranslations(lang);
const presets = await getAllPresets();

const base = getBase();
const categories = ['minimal', 'productivity', 'cost', 'git', 'powerline', 'custom'];
---
<Base>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">{t('hero.badge')}</div>
      <h1 class="hero-title" set:html={t('hero.title').replace('\n', '<br />')} />
      <p class="hero-subtitle">{t('hero.subtitle')}</p>
      <div class="hero-actions">
        <a href="https://github.com/NeTrioGit/claude-statusline-market/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener" class="btn btn-primary">Contribute a Preset</a>
        <a href="https://github.com/NeTrioGit/claude-statusline-market" target="_blank" rel="noopener" class="btn btn-ghost">{t('hero.cta_github')}</a>
      </div>
    </div>
  </section>
  <section id="gallery" class="gallery-section">
    <div class="gallery-inner">
      <div class="gallery-controls">
        <div class="controls-top">
          <input type="search" id="search" class="search-input" placeholder={t('gallery.search_placeholder')} autocomplete="off" />
          <div class="view-toggle" aria-label="view mode">
            <button class="view-btn active" data-view="grid" title="Grid view">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="1" y="1" width="5" height="5" rx="1"/><rect x="8" y="1" width="5" height="5" rx="1"/>
                <rect x="1" y="8" width="5" height="5" rx="1"/><rect x="8" y="8" width="5" height="5" rx="1"/>
              </svg>
            </button>
            <button class="view-btn" data-view="list" title="List view">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="1" y1="3" x2="13" y2="3"/><line x1="1" y1="7" x2="13" y2="7"/><line x1="1" y1="11" x2="13" y2="11"/>
              </svg>
            </button>
          </div>
        </div>
        <div class="category-pills">
          <button class="pill active" data-category="all">{t('gallery.all_categories')}</button>
          {categories.map(cat => (
            <button class="pill" data-category={cat}>{t(`categories.${cat}`)}</button>
          ))}
        </div>
      </div>
      <div class="gallery-count" id="count">{t('gallery.count').replace('{count}', String(presets.length))}</div>
      <div class="grid" id="grid">
        {presets.map(preset => (
          <PresetCard id={preset.id} title={preset.title} description={preset.description} category={preset.category} tags={preset.tags ?? []} tool={preset.tool} lang={lang} base={base} widgets={preset.ccstatusline_settings.lines[0] ?? []} />
        ))}
      </div>
      <div class="empty" id="empty" style="display:none">
        <p id="empty-main">{t('gallery.no_results')}</p>
        <p class="empty-hint" id="empty-hint">{t('gallery.no_results_hint')}</p>
        <p id="empty-cat-msg" style="display:none"></p>
      </div>

      <!-- Contribute CTA -->
      <div class="contribute-cta">
        <p class="contribute-text">Share your preset and help the community grow.</p>
        <a
          href="https://github.com/NeTrioGit/claude-statusline-market/blob/main/CONTRIBUTING.md"
          target="_blank"
          rel="noopener"
          class="btn btn-ghost"
        >Share a Preset</a>
      </div>
    </div>
  </section>
</Base>

<script>
const searchEl = document.getElementById('search') as HTMLInputElement;
const pills = document.querySelectorAll<HTMLElement>('.pill');
const cards = document.querySelectorAll<HTMLElement>('.card');
const countEl = document.getElementById('count')!;
const emptyEl = document.getElementById('empty')!;
const emptyMain = document.getElementById('empty-main')!;
const emptyHint = document.getElementById('empty-hint')!;
const emptyCatMsg = document.getElementById('empty-cat-msg')!;
let activeCategory = 'all';
let query = '';
function filterCards() {
  let visible = 0;
  cards.forEach(card => {
    const title = card.querySelector('.card-title')?.textContent?.toLowerCase() ?? '';
    const desc = card.querySelector('.card-desc')?.textContent?.toLowerCase() ?? '';
    const tags = Array.from(card.querySelectorAll('.tag')).map(t => t.textContent?.toLowerCase() ?? '').join(' ');
    const a = card as HTMLAnchorElement;
    const id = a.href.split('/').pop() ?? '';
    const cardCategory = (card as HTMLElement).dataset.category ?? '';
    const matchesQuery = !query || title.includes(query) || desc.includes(query) || tags.includes(query) || id.includes(query);
    const matchesCat = activeCategory === 'all' || cardCategory === activeCategory;
    const show = matchesQuery && matchesCat;
    (card as HTMLElement).style.display = show ? '' : 'none';
    if (show) visible++;
  });
  const tmpl = countEl.getAttribute('data-template') ?? '';
  countEl.textContent = tmpl.replace('{count}', String(visible));
  emptyEl.style.display = visible === 0 ? '' : 'none';

  if (visible === 0 && activeCategory !== 'all') {
    const label = document.querySelector<HTMLElement>('.pill.active')?.textContent?.trim() ?? activeCategory;
    emptyCatMsg.textContent = `No presets in the '${label}' category.`;
    emptyMain.style.display = 'none';
    emptyHint.style.display = 'none';
    emptyCatMsg.style.display = '';
  } else {
    emptyMain.style.display = '';
    emptyHint.style.display = '';
    emptyCatMsg.style.display = 'none';
  }
}
const rawCount = countEl.textContent ?? '';
countEl.setAttribute('data-template', rawCount.replace(/\d+/, '{count}'));
searchEl?.addEventListener('input', e => { query = (e.target as HTMLInputElement).value.toLowerCase().trim(); filterCards(); });
pills.forEach(pill => { pill.addEventListener('click', () => { pills.forEach(p => p.classList.remove('active')); pill.classList.add('active'); activeCategory = pill.dataset.category ?? 'all'; filterCards(); }); });
const grid = document.getElementById('grid')!;
const viewBtns = document.querySelectorAll<HTMLElement>('.view-btn');
viewBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    viewBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    grid.classList.toggle('list-view', btn.dataset.view === 'list');
  });
});
</script>

<style>
.hero { padding: 6rem 1.5rem 4rem; text-align: center; }
.hero-inner { max-width: 640px; margin: 0 auto; }
.hero-badge { display: inline-block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 0.25rem 0.75rem; border-radius: 999px; margin-bottom: 1.5rem; }
.hero-title { font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 700; letter-spacing: -0.04em; line-height: 1.1; margin-bottom: 1rem; }
.hero-subtitle { font-size: 1rem; color: var(--text-dim); line-height: 1.7; margin-bottom: 2rem; }
.hero-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; padding: 0.625rem 1.25rem; border-radius: var(--radius); font-size: 0.875rem; font-weight: 500; transition: all 0.15s; border: 1px solid transparent; }
.btn-primary { background: var(--accent); color: #000; border-color: var(--accent); }
.btn-primary:hover { opacity: 0.88; }
.btn-ghost { border-color: var(--border); color: var(--text-dim); }
.btn-ghost:hover { border-color: var(--border-hover); color: var(--text); background: var(--bg-hover); }
.gallery-section { padding: 0 1.5rem 4rem; }
.gallery-inner { max-width: 1200px; margin: 0 auto; }
.gallery-controls { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.5rem; }
.controls-top { display: flex; align-items: center; gap: 0.75rem; }
.search-input { flex: 1; padding: 0.625rem 1rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-size: 0.875rem; font-family: inherit; outline: none; transition: border-color 0.15s; }
.search-input:focus { border-color: var(--accent); }
.search-input::placeholder { color: var(--text-muted); }
.category-pills { display: flex; flex-wrap: wrap; gap: 0.375rem; }
.pill { padding: 0.3125rem 0.875rem; border-radius: 999px; border: 1px solid var(--border); background: transparent; color: var(--text-dim); font-size: 0.8125rem; font-family: inherit; cursor: pointer; transition: all 0.15s; }
.pill:hover { border-color: var(--border-hover); color: var(--text); }
.pill.active { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
.gallery-count { font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 1.5rem; }
.view-toggle { display: flex; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; flex-shrink: 0; }
.view-btn { display: flex; align-items: center; justify-content: center; padding: 0.4rem 0.625rem; background: transparent; border: none; color: var(--text-muted); cursor: pointer; transition: color 0.15s, background 0.15s; }
.view-btn:hover { color: var(--text-dim); background: var(--bg-hover); }
.view-btn.active { color: var(--accent); background: var(--accent-dim); }
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
.grid.list-view { grid-template-columns: 1fr; gap: 0.5rem; }
.grid.list-view :global(.card) { flex-direction: row; height: 80px; overflow: hidden; }
.grid.list-view :global(.card-info) { order: 0; width: 220px; flex-shrink: 0; padding: 0.625rem 0.875rem; display: flex; flex-direction: column; justify-content: center; }
.grid.list-view :global(.card-divider) { order: 1; width: 1px; height: auto; background: linear-gradient(180deg, #161616 0%, #1e1e1e 50%, #161616 100%); }
.grid.list-view :global(.card-terminal) { order: 2; flex: 1; min-width: 0; }
.grid.list-view :global(.card-tags) { display: none; }
.grid.list-view :global(.card-desc) { display: none; }
.grid.list-view :global(.term-footer) { display: none; }
.empty { text-align: center; padding: 4rem 1rem; }
.empty p { color: var(--text-dim); margin-bottom: 0.5rem; }
.empty-hint { font-size: 0.875rem; color: var(--text-muted); }
.contribute-cta { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 3rem; padding: 1.25rem 1.5rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg-card); flex-wrap: wrap; }
.contribute-text { font-size: 0.9375rem; color: var(--text-dim); margin: 0; flex: 1; min-width: 200px; }
</style>
